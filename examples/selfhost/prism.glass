# v4.27: parens-after-let parser fix in prism. The trailing
# `(r1, r2)` on a new line at column 1 used to be eaten as a call
# against the previous let's value. v4.27 injects a TNlBdy boundary
# marker before such an `(`, and parse_app_loop uses it to break the
# postfix-call chain. Mirrors the v4.21 host fix.
let _ : String = match read_file("examples/features/parens_after_let.glass") {
  Ok(src) =>
    match compile(src) {
      Ok(triple) =>
        match triple {
          (t, eff, v) =>
            print("examples/features/parens_after_let.glass ==> " ++ show_value(v) ++ " : " ++ show_type(t))
        };
      Err(msg) => print("examples/features/parens_after_let.glass ==> " ++ msg)
    };
  Err(msg) => print("read error: " ++ msg)
}

