# v4.25: return-type refinement runtime checks. The parser now accepts
# `where (result <pred>)` after a fn's return type, and the VRefinedClos
# wrapper carries the return type forward so it can be checked against
# the final value on the last apply. 1-param fns check the return
# refinement immediately at the VMutRecClos branch.
let _ : String = match read_file("examples/features/return_refine.glass") {
  Ok(src) =>
    match compile(src) {
      Ok(triple) =>
        match triple {
          (t, eff, v) =>
