# THE STAGE 3 SHOWPIECE: a mini interpreter for an expression language
# with int literals, +/-/*, variables, and let-bindings. Written in
# prism.glass's exact surface syntax — top-level type decl, multiple
# top-level fn decls (mutually recursive via eval_expr), pattern
# matching on ADTs and tuples, generic List manipulation. This is
# what Stage 3 self-host looks like in practice.
let _ : String = report("
# A tiny expression language
type Expr = | EInt(Int)
            | EAdd(Expr, Expr)
            | ESub(Expr, Expr)
            | EMul(Expr, Expr)
            | EVar(String)
            | ELet(String, Expr, Expr)

# Environment lookup. Returns 0 if not found (no error handling
# in this tiny demo — we trust the input).
fn lookup(env: List<(String, Int)>, name: String) : Int =
  match env {
    [] => 0;
    [(k, v), ...rest] =>
      if string_eq(k)(name) then v else lookup(rest, name)
  }

# Evaluator: takes an Expr and an env, returns the integer value.
fn eval_expr(e: Expr, env: List<(String, Int)>) : Int =
  match e {
    EInt(n) => n;
    EAdd(a, b) => eval_expr(a, env) + eval_expr(b, env);
    ESub(a, b) => eval_expr(a, env) - eval_expr(b, env);
    EMul(a, b) => eval_expr(a, env) * eval_expr(b, env);
    EVar(name) => lookup(env, name);
    ELet(name, value, body) =>
      let v = eval_expr(value, env) in
      eval_expr(body, [(name, v), ...env])
  }

# Test: let x = 10 in x * (x - 3)  ==>  70
let prog = ELet(\"x\", EInt(10),
                EMul(EVar(\"x\"), ESub(EVar(\"x\"), EInt(3))))
eval_expr(prog, [])
")

# v0.9.6 — `print` builtin and effect annotations in fn signatures.
let _ : String = print("--- print + effect annotations ---")
# Inferred IO from print call
let _ : String = report("print(\"hello from inside prism.glass\")")
# Function with explicit !{IO} annotation
let _ : String = report("
fn greet(name: String) : String !{IO} = print(\"hi, \" ++ name)
greet(\"world\")
")
# Mixed effects: pure fn calling another pure fn
let _ : String = report("
fn double(x: Int) : Int = x * 2
fn quad(x: Int) : Int = double(double(x))
quad(7)
")
# Effectful + pure composition
let _ : String = report("
fn shout(s: String) : String !{IO} = print(s ++ \"!\")
fn loud(s: String) : String !{IO} = shout(shout(s))
loud(\"hey\")
")
# Pattern: print intermediate, return final
let _ : String = report("
fn compute(x: Int) : Int !{IO} =
  let _ = print(\"computing for \" ++ int_to_str(x)) in
  x * x + 1
compute(7)
")

# THE DEFINITIVE STAGE 3 TEST: a substantial Glass program — using
# almost every feature prism.glass supports — passed through compile().
# This is two interpretation levels: glass.py runs prism.glass, which
# runs compile() on a string of Glass source, which lexes / parses /
# type-checks / evaluates the inner program. The inner program builds
# and walks a binary tree, exercising recursion, ADTs, generics,
# tuples, pattern matching, and arithmetic.
let _ : String = report("type Tree = | Leaf | Node(Int, Tree, Tree)
fn size(t: Tree) : Int =
  match t {
    Leaf => 0;
    Node(_, l, r) => 1 + size(l) + size(r)
  }
size(Node(1, Node(2, Leaf, Leaf), Node(3, Leaf, Leaf)))")

let _ : String = report("(1, 2)")
let _ : String = report("let x = 1 in (x, x)")
let _ : String = report("type Tree<A> = | Leaf | Node(A, Tree<A>, Tree<A>)
fn insert(t: Tree<Int>, x: Int) : Tree<Int> =
  match t {
    Leaf => Node(x, Leaf, Leaf);
    Node(v, l, r) =>
      if x < v then Node(v, insert(l, x), r)
      else Node(v, l, insert(r, x))
  }
fn size(t: Tree<Int>) : Int =
  match t {
    Leaf => 0;
    Node(_, l, r) => 1 + size(l) + size(r)
  }
fn sum_tree(t: Tree<Int>) : Int =
  match t {
    Leaf => 0;
    Node(v, l, r) => v + sum_tree(l) + sum_tree(r)
  }
fn build_tree(xs: List<Int>) : Tree<Int> =
  match xs {
    [] => Leaf;
    [h, ...t] => insert(build_tree(t), h)
  }
let t = build_tree([5, 2, 8, 1, 9, 3, 7]) in
(size(t), sum_tree(t))
")

# The mini.glass program in prism.glass surface syntax — a small
# Hindley-Milner-style interpreter for an expression language. Tests
# whether prism.glass can parse + type + eval substantial Glass-style
# code with multiple ADTs, recursive fns, generic types, and Result
# monad chaining. This is the empirical Stage-3 step.
let _ : String = report("
# Declare Pair and Result (host has them built-in; prism.glass doesn't yet)
type Pair<A, B> = | Pair(A, B)
type Result<A, B> = | Ok(A) | Err(B)

# AST and runtime values
type Expr = | EInt(Int) | EBool(Bool) | EVar(String)
            | EAdd(Expr, Expr) | EMul(Expr, Expr) | ELt(Expr, Expr)
            | EIf(Expr, Expr, Expr) | ELet(String, Expr, Expr)
            | EFn(String, Expr) | EApp(Expr, Expr)

type Value = | VInt(Int) | VBool(Bool)
             | VClos(String, Expr, List<Pair<String, Value>>)

# Environment lookup using Result monad
fn lookup(env: List<Pair<String, Value>>, name: String) : Result<Value, String> =
  match env {
    [] => Err(\"unbound: \" ++ name);
    [Pair(k, v), ...rest] =>
      if string_eq(k)(name) then Ok(v) else lookup(rest, name)
  }

# Result monad bind — chain Result-returning operations.
fn bind_result(r: Result<Value, String>, k: (Value) -> Result<Value, String>) : Result<Value, String> =
  match r {
    Err(e) => Err(e);
    Ok(v) => k(v)
  }

# The evaluator. Mutually recursive with itself (deeply via eval_args
# for EApp). Uses bind_result for Result-monad chaining.
fn eval(e: Expr, env: List<Pair<String, Value>>) : Result<Value, String> =
  match e {
    EInt(n) => Ok(VInt(n));
    EBool(b) => Ok(VBool(b));
    EVar(x) => lookup(env, x);
    EAdd(a, b) =>
      bind_result(eval(a, env), fn(va) ->
        bind_result(eval(b, env), fn(vb) ->
          match va {
            VInt(x) =>
              match vb {
                VInt(y) => Ok(VInt(x + y));
                _ => Err(\"add: rhs not Int\")
              };
            _ => Err(\"add: lhs not Int\")
          }));
    EMul(a, b) =>
      bind_result(eval(a, env), fn(va) ->
        bind_result(eval(b, env), fn(vb) ->
          match va {
            VInt(x) =>
              match vb {
                VInt(y) => Ok(VInt(x * y));
                _ => Err(\"mul: rhs not Int\")
              };
            _ => Err(\"mul: lhs not Int\")
          }));
    ELt(a, b) =>
      bind_result(eval(a, env), fn(va) ->
        bind_result(eval(b, env), fn(vb) ->
          match va {
            VInt(x) =>
              match vb {
                VInt(y) => Ok(VBool(x < y));
                _ => Err(\"lt: rhs not Int\")
              };
            _ => Err(\"lt: lhs not Int\")
          }));
    EIf(c, t, e2) =>
      bind_result(eval(c, env), fn(vc) ->
        match vc {
          VBool(b) => if b then eval(t, env) else eval(e2, env);
          _ => Err(\"if: cond not Bool\")
        });
    ELet(x, v, body) =>
      bind_result(eval(v, env), fn(vv) ->
        eval(body, [Pair(x, vv), ...env]));
    EFn(x, body) => Ok(VClos(x, body, env));
    EApp(f, a) =>
      bind_result(eval(f, env), fn(vf) ->
        bind_result(eval(a, env), fn(va) ->
          match vf {
            VClos(p, body, cenv) =>
              eval(body, [Pair(p, va), ...cenv]);
            _ => Err(\"app: not a function\")
          }))
  }

# Test program: (fn(x) -> x * x + 1)(5)
let prog = EApp(EFn(\"x\", EAdd(EMul(EVar(\"x\"), EVar(\"x\")), EInt(1))), EInt(5)) in
eval(prog, [])
")

# v0.9.8 — literal patterns: PBool, PInt, PStr inside match arms.
let _ : String = print("--- literal patterns ---")
let _ : String = report("match 5 { 0 => \"zero\"; 1 => \"one\"; _ => \"many\" }")
let _ : String = report("match true { true => 1; false => 0 }")
let _ : String = report("match \"foo\" { \"foo\" => 1; \"bar\" => 2; _ => 0 }")
# Literal inside a constructor
let _ : String = report("type Cell = | Empty | Filled(Int)
match Filled(0) { Filled(0) => \"zero cell\"; Filled(_) => \"nonzero cell\"; Empty => \"empty\" }")
let _ : String = report("type Cell = | Empty | Filled(Int)
match Filled(42) { Filled(0) => \"zero cell\"; Filled(_) => \"nonzero cell\"; Empty => \"empty\" }")
# A FizzBuzz-style with literal patterns
let _ : String = report("fn classify(n: Int) : String =
  match n {
    0 => \"zero\";
    1 => \"one\";
    2 => \"two\";
    _ => \"many\"
  }
classify(2) ++ \", \" ++ classify(99)")

# Errors with sum types
let _ : String = print("--- sum-type errors ---")
let _ : String = report("1 + ")               # parse error
let _ : String = report("undefined")          # type error (unbound)
let _ : String = report("1 + true")           # type error (mismatch)
let _ : String = report("if 5 then 1 else 2") # type error (cond not Bool)
let _ : String = report("fn(x) -> x(x)")      # type error (occurs check)
let _ : String = report("{ x: 1 }.missing")   # type error (no such field)
let _ : String = report("(fn(r) -> r.x)({ y: 1 })")  # type error (wrong record shape)


# v0.9.8 — the Stage-3 capstone demo. Read a Glass source file from
# disk via the `read_file` builtin (effect !{File}), then compile it
# through prism.glass's own compile pipeline. Two levels deep:
# glass.py runs prism.glass, which loads tiny.glass from disk and
# parses + types + evaluates it.
let _ : String = print("--- read + compile from disk ---")
let _ : String = match read_file("examples/stage3/tiny.glass") {
  Ok(src) =>
    match compile(src) {
      Ok(triple) =>
        match triple {
          (t, eff, v) =>
            print("examples/stage3/tiny.glass ==> " ++ show_value(v) ++ " : " ++ show_type(t))
        };
      Err(msg) => print("compile error: " ++ msg)
    };
  Err(msg) => print("read error: " ++ msg)
}
let _ : String = match read_file("examples/stage3/poly.glass") {
  Ok(src) =>
    match compile(src) {
      Ok(triple) =>
        match triple {
          (t, eff, v) =>
            print("examples/stage3/poly.glass ==> " ++ show_value(v) ++ " : " ++ show_type(t))
        };
      Err(msg) => print("compile error: " ++ msg)
    };
  Err(msg) => print("read error: " ++ msg)
}


# What this file proves: the v1.0 shape composes. A single Glass program
# takes a string of source code and produces a typed value. Each stage
# (lexer, parser, inferer, evaluator) was proven in earlier releases;
# this file is the assembly that demonstrates they work together.
#
# v1.0 is scaling the grammar (more constructs), the type system (more
# kinds, effects, refinements), and the runtime (more builtins, ADTs)
# without changing this overall shape. The pipeline is established;
# the remaining work is volume.
