# recursive computations — fold, map, filter, sum over recursive ADTs.
let _ : String = print("--- recursion ---")
let _ : String = report("let rec sum = fn(xs) -> match xs {
  [] => 0;
  [h, ...t] => h + sum(t)
} in sum([1, 2, 3, 4])")
