# v4.56: cross-parameter refinement. `hi > lo` references an earlier
# param; prism threads the applied args through VRefinedClos so it
# resolves. clamp(3, 10) = 7.
let _ : String = match read_file("examples/features/xparam_refine.glass") {
  Ok(src) =>
    match compile(src) {
      Ok(triple) =>
        match triple {
