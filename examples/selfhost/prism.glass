# v4.23: refinement runtime checks. The argument here is a let-bound
# variable, so const-fold static discharge defers and prism's new
# runtime check fires on entry to the fn. Positive case (predicate
# holds): the call returns its result normally. Negative case (predicate
# fails): the call returns Err with "refinement violated at runtime",
# which propagates through compile() and surfaces as a "compile error"
# in the demo loop.
let _ : String = match read_file("examples/features/runtime_refine.glass") {
  Ok(src) =>
    match compile(src) {
      Ok(triple) =>
        match triple {
          (t, eff, v) =>
            print("examples/features/runtime_refine.glass ==> " ++ show_value(v) ++ " : " ++ show_type(t))
        };
      Err(msg) => print("compile error: " ++ msg)
    };
  Err(msg) => print("read error: " ++ msg)
}

let _ : String = match read_file("examples/features/runtime_refine_bad.glass") {
  Ok(src) =>
    match compile(src) {
      Ok(triple) =>
        match triple {
          (t, eff, v) =>
            print("examples/features/runtime_refine_bad.glass ==> " ++ show_value(v) ++ " : " ++ show_type(t))
        };
      Err(msg) => print("examples/features/runtime_refine_bad.glass ==> " ++ msg)
    };
  Err(msg) => print("read error: " ++ msg)
}

# v4.24: refinement runtime checks on later parameters of curried
# top-level fns. The VRefinedClos wrapper carries the remaining formal
