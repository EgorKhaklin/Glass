  [] => [];
  [h, ...t] => [f(h), ...map(f)(t)]
} in
let rec sum = fn(xs) -> match xs {
  [] => 0;
  [h, ...t] => h + sum(t)
} in
sum(map(tick)([1, 2, 3]))")

