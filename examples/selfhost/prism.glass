# v0.9.4 — strings as a first-class type. The fundamental missing piece
# for Stage 3 self-host: prism.glass's own source code is a String, and
# without TyStr/VStr/EStr, prism.glass cannot interpret programs that
# manipulate strings. This is the foundation.
let _ : String = print("--- strings ---")
let _ : String = report("\"hello\"")
let _ : String = report("\"hello, \" ++ \"world\"")
let _ : String = report("let g = \"glass\" in g ++ \" v0.9.4\"")
# Strings are first-class: can be in tuples, lists, records.
let _ : String = report("(\"a\", 1, true)")
let _ : String = report("[\"alpha\", \"beta\", \"gamma\"]")
let _ : String = report("{ name: \"prism\", version: \"v0.9.4\" }")
# Strings flow through generic ADTs.
let _ : String = report("[\"a\", \"b\"] ++ \"c\"")  # type error: list ++ string
let _ : String = report("let rec concat_all = fn(xs) -> match xs {
  [] => \"\";
  [h, ...t] => h ++ concat_all(t)
} in concat_all([\"Glass \", \"is \", \"strings.\"])")
# String-returning function inferred polymorphically? No — return type concrete.
let _ : String = report("fn(s) -> s ++ \"!\"")
# String access pattern: use match on field
let _ : String = report("let r = { msg: \"hello\", n: 7 } in r.msg ++ \" world\"")

# String-inspection builtins — the bridge to Stage 3. These let
# prism.glass programs read their own input character-by-character,
# which is the foundation of a tokenizer.
let _ : String = print("--- string builtins ---")
let _ : String = report("string_length(\"hello\")")
let _ : String = report("string_length(\"\")")
let _ : String = report("char_at(\"abc\")(0)")
let _ : String = report("char_at(\"abc\")(2)")
let _ : String = report("int_to_str(42)")
let _ : String = report("int_to_str(0 - 17)")
let _ : String = report("string_eq(\"foo\")(\"foo\")")
let _ : String = report("string_eq(\"foo\")(\"bar\")")
# Composition: render a number as a string and concatenate.
let _ : String = report("\"answer = \" ++ int_to_str(6 * 7)")
# Recursion over a string, character by character.
let _ : String = report("let rec count_a = fn(s) -> fn(i) ->
  if i >= string_length(s) then 0
  else if string_eq(char_at(s)(i))(\"a\") then 1 + count_a(s)(i + 1)
  else count_a(s)(i + 1)
in count_a(\"banana, apricot, avocado\")(0)")
# A miniature tokenizer-shaped function: explode a string into a list of chars
let _ : String = report("let rec all_chars = fn(s) -> fn(i) ->
  if i >= string_length(s) then []
  else [char_at(s)(i), ...all_chars(s)(i + 1)]
in all_chars(\"glass\")(0)")

# THE STAGE 3 PROOF OF CONCEPT: a real tokenizer running inside
# prism.glass, which is itself running on glass.py. This is two
# levels of interpretation deep: glass.py interprets prism.glass,
# which interprets a tokenizer that reads characters from a string.
# If we had top-level fn decls, prism.glass could interpret prism.glass.
let _ : String = report("
type Token = | TNum(Int) | TPlus | TMinus | TLParen | TRParen | TBad(String)

let is_digit_char = fn(c) ->
  if string_eq(c)(\"0\") then true
  else if string_eq(c)(\"1\") then true
  else if string_eq(c)(\"2\") then true
  else if string_eq(c)(\"3\") then true
  else if string_eq(c)(\"4\") then true
  else if string_eq(c)(\"5\") then true
  else if string_eq(c)(\"6\") then true
  else if string_eq(c)(\"7\") then true
  else if string_eq(c)(\"8\") then true
  else if string_eq(c)(\"9\") then true
  else false
in

let digit_val = fn(c) ->
  if string_eq(c)(\"0\") then 0
  else if string_eq(c)(\"1\") then 1
  else if string_eq(c)(\"2\") then 2
  else if string_eq(c)(\"3\") then 3
  else if string_eq(c)(\"4\") then 4
  else if string_eq(c)(\"5\") then 5
  else if string_eq(c)(\"6\") then 6
  else if string_eq(c)(\"7\") then 7
  else if string_eq(c)(\"8\") then 8
  else 9
in

let rec read_num = fn(s) -> fn(i) -> fn(acc) ->
  if i >= string_length(s) then (acc, i)
  else if is_digit_char(char_at(s)(i)) then
    read_num(s)(i + 1)(acc * 10 + digit_val(char_at(s)(i)))
  else (acc, i)
in

let rec tokenize = fn(s) -> fn(i) ->
  if i >= string_length(s) then []
  else
    let c = char_at(s)(i) in
    if string_eq(c)(\" \") then tokenize(s)(i + 1)
    else if string_eq(c)(\"+\") then [TPlus, ...tokenize(s)(i + 1)]
    else if string_eq(c)(\"-\") then [TMinus, ...tokenize(s)(i + 1)]
    else if string_eq(c)(\"(\") then [TLParen, ...tokenize(s)(i + 1)]
    else if string_eq(c)(\")\") then [TRParen, ...tokenize(s)(i + 1)]
    else if is_digit_char(c) then
      match read_num(s)(i)(0) { (n, j) => [TNum(n), ...tokenize(s)(j)] }
    else
      [TBad(c), ...tokenize(s)(i + 1)]
in

tokenize(\"12 + 34 - (5)\")(0)
")

