fn answer(_: Int) : Int = 42  # always
answer(0)")

# fn decl + type decl
let _ : String = report("type Tree = | Leaf | Node(Int, Tree, Tree)
fn size(t: Tree) : Int = match t {
  Leaf => 0;
  Node(_, l, r) => 1 + size(l) + size(r)
}
size(Node(1, Node(2, Leaf, Leaf), Node(3, Leaf, Node(4, Leaf, Leaf))))")

# THE STAGE 3 PROOF: a small program written in the EXACT prism.glass-
# style surface — top-level fn decls, type decl, comments, strings,
# multi-arg fns, pattern matching, mutual recursion — running inside
# prism.glass. This is the shape of self-host.
let _ : String = report("
# A tiny calculator: parse + evaluate a string like \"1+2+3\".
# Two top-level fns calling each other (mutual recursion).
type Tok = | Num(Int) | Op(String) | End

fn digit(c: String) : Bool =
  if string_eq(c)(\"0\") then true
  else if string_eq(c)(\"1\") then true
  else if string_eq(c)(\"2\") then true
  else if string_eq(c)(\"3\") then true
  else if string_eq(c)(\"4\") then true
  else if string_eq(c)(\"5\") then true
  else if string_eq(c)(\"6\") then true
  else if string_eq(c)(\"7\") then true
  else if string_eq(c)(\"8\") then true
  else if string_eq(c)(\"9\") then true
  else false

fn dval(c: String) : Int =
  if string_eq(c)(\"0\") then 0
  else if string_eq(c)(\"1\") then 1
  else if string_eq(c)(\"2\") then 2
  else if string_eq(c)(\"3\") then 3
  else if string_eq(c)(\"4\") then 4
  else if string_eq(c)(\"5\") then 5
  else if string_eq(c)(\"6\") then 6
  else if string_eq(c)(\"7\") then 7
  else if string_eq(c)(\"8\") then 8
  else 9

# Read a number from position i, accumulating. Returns (value, new_pos).
fn read_num(s: String, i: Int, acc: Int) : (Int, Int) =
  if i >= string_length(s) then (acc, i)
  else if digit(char_at(s)(i)) then
    read_num(s, i + 1, acc * 10 + dval(char_at(s)(i)))
  else (acc, i)

# Top-level evaluator: take a string, return its computed value.
# Calls read_num. Uses string_eq for op dispatch.
fn calc(s: String, i: Int, acc: Int) : Int =
  if i >= string_length(s) then acc
  else if digit(char_at(s)(i)) then
    match read_num(s, i, 0) { (n, j) => calc(s, j, acc + n) }
  else calc(s, i + 1, acc)

calc(\"100 + 23 + 4 + 5\", 0, 0)
")

