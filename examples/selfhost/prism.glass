  [] => 0;
  [_, ...t] => 1 + length(t)
} in length([10, 20, 30])")
let _ : String = report("let rec map = fn(f) -> fn(xs) -> match xs {
  [] => [];
  [h, ...t] => [f(h), ...map(f)(t)]
} in
let rec sum = fn(xs) -> match xs {
  [] => 0;
  [h, ...t] => h + sum(t)
} in
sum(map(fn(n) -> n + 100)([1, 2, 3]))")
let _ : String = report("let rec append = fn(xs) -> fn(ys) -> match xs {
  [] => ys;
  [h, ...t] => [h, ...append(t)(ys)]
} in
let rec sum = fn(xs) -> match xs {
  [] => 0;
  [h, ...t] => h + sum(t)
} in
sum(append([1, 2])([10, 20, 30]))")
