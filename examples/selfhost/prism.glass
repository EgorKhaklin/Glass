# Stage 4.5 (v2.15): prism compiles a meaningful subset of its own source.
# The subset is types + complete lexer chain (~320 lines), proving prism
# can parse, type-check, AND evaluate self-referential Glass code.
let _ : String = match read_file("examples/selfhost/prism_lexer.glass") {
  Ok(src) =>
    match compile(src) {
      Ok(triple) =>
        match triple {
          (t, eff, v) =>
            print("STAGE 4.5: examples/selfhost/prism_lexer.glass ==> " ++ show_value(v) ++ " : " ++ show_type(t))
        };
      Err(msg) => print("compile error: " ++ msg)
    };
  Err(msg) => print("read error: " ++ msg)
}

# Stage 5 piece (v3.6): prism interprets quartz_min.glass — a Glass program
# that compiles a small subset of Glass to C source code. Demonstrates the
# self-host-plus-native pipeline: prism interprets Quartz-in-Glass which
# produces C; that C, fed to cc, becomes a native binary.
let _ : String = match read_file("examples/selfhost/quartz_min.glass") {
  Ok(src) =>
    match compile(src) {
      Ok(triple) =>
        match triple {
          (t, eff, v) =>
            print("STAGE 5 piece: examples/selfhost/quartz_min.glass ==> Quartz-in-Glass produced " ++ show_type(t) ++ " of C source")
        };
      Err(msg) => print("compile error: " ++ msg)
    };
  Err(msg) => print("read error: " ++ msg)
}


# What this file proves: the v1.0 shape composes. A single Glass program
# takes a string of source code and produces a typed value. Each stage
# (lexer, parser, inferer, evaluator) was proven in earlier releases;
# this file is the assembly that demonstrates they work together.
#
# v1.0 is scaling the grammar (more constructs), the type system (more
# kinds, effects, refinements), and the runtime (more builtins, ADTs)
# without changing this overall shape. The pipeline is established;
# the remaining work is volume.
