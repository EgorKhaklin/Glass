# v4.52: `&&` and `||` end-to-end through prism. v4.51 landed the
# operators in host + Quartz but deferred prism's lexer/parser/Expr/
# infer/eval. This file is the canonical interval refinement, which
# was unwritable in prism prior to this release.
let _ : String = match read_file("examples/features/and_or.glass") {
  Ok(src) =>
    match compile(src) {
      Ok(triple) =>
        match triple {
          (t, eff, v) =>
            print("examples/features/and_or.glass ==> " ++ show_value(v) ++ " : " ++ show_type(t))
        };
      Err(msg) => print("examples/features/and_or.glass ==> " ++ msg)
    };
  Err(msg) => print("read error: " ++ msg)
}

# v4.53: modulo lands. Parity refinements like `n % 2 == 0` are
# now expressible across host + Quartz + prism. The canonical case.
let _ : String = match read_file("examples/features/mod_refine.glass") {
  Ok(src) =>
    match compile(src) {
      Ok(triple) =>
        match triple {
          (t, eff, v) =>
            print("examples/features/mod_refine.glass ==> " ++ show_value(v) ++ " : " ++ show_type(t))
        };
      Err(msg) => print("examples/features/mod_refine.glass ==> " ++ msg)
    };
  Err(msg) => print("read error: " ++ msg)
}

# v4.54: unary NOT. `!(n == 0)` rounds out the boolean trio
# (&& v4.51, || v4.52, ! v4.54). nonzero(5) = 100 / 5 = 20.
let _ : String = match read_file("examples/features/not_refine.glass") {
  Ok(src) =>
    match compile(src) {
      Ok(triple) =>
        match triple {
          (t, eff, v) =>
            print("examples/features/not_refine.glass ==> " ++ show_value(v) ++ " : " ++ show_type(t))
        };
      Err(msg) => print("examples/features/not_refine.glass ==> " ++ msg)
    };
  Err(msg) => print("read error: " ++ msg)
}

# v4.68: linear types in prism — a `let lin` resource must be consumed
# exactly once. The OK case compiles to 50; the clone case is rejected
# at parse time with "used 2 times (no cloning)".
let _ : String = match read_file("examples/features/linear_ok.glass") {
