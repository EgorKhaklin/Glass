fn p_circ(d: Int) : List<Int> = [17, 15, 41, 16, 2, 28, 13, 13, 39, 18, 34, 20]
fn pzero(n: Int) : List<List<Int>> = if n <= 0 then [] else [glit(0)] ++ pzero(n - 1)   # glit(0) trims to [] (field 0), but is typed List<Int> so HM infers List<List<Int>>
# --- WIDE hash: 4 Poseidon lanes (~256-bit -> ~128-bit collision binding), fixing the
# prior single-lane (~64-bit -> ~32-bit) Merkle/transcript cap (audit finding #1). hashg
# KEEPS its (List<Int>,List<Int>)->List<Int> signature: a "hash" is now 16 limbs (4 lanes
# x 4), a single field element is <=4 limbs; to_lanes splits either; lane0 extracts a
# field element where a challenge needs one. Opaque Merkle/transcript/digest uses are
# UNCHANGED. q_low/pow_ok read the first limb (= lane 0's first limb), also unchanged.
fn lcnt(x: List<Int>) : Int = match x { [] => 0; [h, ...t] => 1 + lcnt(t) }
fn pad4l(x: List<Int>) : List<Int> = if lcnt(x) >= 4 then x else pad4l(x ++ [0])
fn first4(x: List<Int>) : List<Int> = match x { [] => []; [a, ...t1] => match t1 { [] => [a]; [b, ...t2] => match t2 { [] => [a, b]; [c, ...t3] => match t3 { [] => [a, b, c]; [d, ...t4] => [a, b, c, d] } } } }
fn drop4(x: List<Int>) : List<Int> = match x { [] => []; [a, ...t1] => match t1 { [] => []; [b, ...t2] => match t2 { [] => []; [c, ...t3] => match t3 { [] => []; [d, ...t4] => t4 } } } }
fn to_lanes(x: List<Int>) : List<List<Int>> = if lcnt(x) <= 4 then [pad4l(x)] else [first4(x)] ++ to_lanes(drop4(x))
fn lanepad12(ls: List<List<Int>>) : List<List<Int>> = if llen(ls) >= 12 then ls else lanepad12(ls ++ [[0, 0, 0, 0]])
fn from4(st: List<List<Int>>) : List<Int> = pad4l(wnth(st, 0)) ++ pad4l(wnth(st, 1)) ++ pad4l(wnth(st, 2)) ++ pad4l(wnth(st, 3))
fn lane0(h: List<Int>) : List<Int> = first4(h)
fn hashg(a: List<Int>, b: List<Int>) : List<Int> = from4(perm(p_arc(0), p_circ(0), lanepad12(to_lanes(a) ++ to_lanes(b))))
fn rand_coeffs(seed: Int, i: Int, k: Int) : List<List<Int>> = if i >= k then [] else [lane0(hashg(glit(seed), glit(i + 1)))] ++ rand_coeffs(seed, i + 1, k)
# --- ZK BLINDING (mechanism). T'(x) = T(x) + Z_H(x)*R(x): on H, Z_H=0 so T'=T (every gate
# constraint preserved); off H (the coset, where queries open) the Z_H*R mask randomizes the
# value, HIDING the witness. Full ZK = blind l,r,o,Z with deg(R) >= the ~166-eval leak surface,
# integrated into the staged FRI (the heavy part — design in docs/tier1-zk-design.md). Here we
# implement the blinding and demonstrate the HIDING property fast (no FRI).
fn zh_at(x: List<Int>, n: Int) : List<Int> = fsub(fpow_bn(x, glit(n)), [1])
fn blind_col(cw: List<List<Int>>, coset: List<List<Int>>, rco: List<List<Int>>, n: Int, i: Int, m: Int) : List<List<Int>> =
  if i >= m then [] else [fadd(wnth(cw, i), fmul(zh_at(wnth(coset, i), n), poly_eval_b(rco, wnth(coset, i))))] ++ blind_col(cw, coset, rco, n, i + 1, m)
# Hiding smoke test: blind the SAME witness column with two mask seeds; the opened value at a
# coset point must (a) differ from the raw witness value (masked) and (b) differ between the two
# masks (randomized) — so the opening reveals the mask, not the witness.
fn zk_hiding(seed1: Int, seed2: Int) : Bool =
  let n : Int = 8 in let coset : List<List<Int>> = fri_coset(n) in let m : Int = fri_dsize(n) in
  let lvals : List<List<Int>> = [glit(2), glit(3), glit(5), glit(7), glit(11), glit(13), glit(17), glit(19)] in
  let lcw : List<List<Int>> = eval_on_dom(interp_n(lvals, n), coset) in
  let b1 : List<List<Int>> = blind_col(lcw, coset, rand_coeffs(seed1, 0, 16), n, 0, m) in
  let b2 : List<List<Int>> = blind_col(lcw, coset, rand_coeffs(seed2, 0, 16), n, 0, m) in
  let masked : Bool = if bn_eq(wnth(b1, 5), wnth(lcw, 5)) then false else true in
  let diff_masks : Bool = if bn_eq(wnth(b1, 5), wnth(b2, 5)) then false else true in
  masked && diff_masks
fn blind_cw(cw: List<List<Int>>, coeffs: List<List<Int>>, dom: List<List<Int>>, i: Int) : List<List<Int>> =
  if i >= llen(cw) then [] else [fadd(wnth(cw, i), poly_eval_b(coeffs, wnth(dom, i)))] ++ blind_cw(cw, coeffs, dom, i + 1)
fn prove_zk(gates: List<Gate>, w: List<List<Int>>, seed: Int) : Bool =
  let bcw : List<List<Int>> = blind_cw(q_cw(gates, w), rand_coeffs(seed, 0, 16), fri_coset(ng(gates)), 0) in
  is_constb(fold_all_b(bcw, fri_coset(ng(gates)), finv([2]), 0))
fn opened5(gates: List<Gate>, w: List<List<Int>>, seed: Int) : List<Int> =
  wnth(blind_cw(q_cw(gates, w), rand_coeffs(seed, 0, 16), fri_coset(ng(gates)), 0), 5)

# --- the cryptographic STARK: F_{p^2} fold challenge + Merkle commit + queries --
# Embed the quotient codeword into F_{p^2}, blind it, Merkle-commit each FRI layer,
# derive the fold challenge β ∈ F_{p^2} ≈ 2^128 from each layer's root (Fiat-Shamir,
# so it's unpredictable), and OPEN sampled positions against the commitment: a
# prover whose Q is not low-degree is caught at (almost) every query. This is the
# production STARK shape, on the production field. (FRI over F_{p^2} + Merkle from
# frost_goldilocks_zk.glass, here applied to the gate quotient.)
type G2 = | G2(List<Int>, List<Int>)
fn gadd2(a: G2, b: G2) : G2 = match a { G2(a0, a1) => match b { G2(b0, b1) => G2(fadd(a0, b0), fadd(a1, b1)) } }
fn gsub2(a: G2, b: G2) : G2 = match a { G2(a0, a1) => match b { G2(b0, b1) => G2(fsub(a0, b0), fsub(a1, b1)) } }
fn gscale2(a: G2, s: List<Int>) : G2 = match a { G2(a0, a1) => G2(fmul(a0, s), fmul(a1, s)) }
fn gmul2(a: G2, b: G2) : G2 = match a { G2(a0, a1) => match b { G2(b0, b1) => G2(fadd(fmul(a0, b0), fmul([7], fmul(a1, b1))), fadd(fmul(a0, b1), fmul(a1, b0))) } }
fn geq2(a: G2, b: G2) : Bool = match a { G2(a0, a1) => match b { G2(b0, b1) => bn_eq(a0, b0) && bn_eq(a1, b1) } }
# --- F_{p^2} ops for the TIER-1 OOD/DEEP soundness check (u^2 = 7) --------------
fn gconj(a: G2) : G2 = match a { G2(a0, a1) => G2(a0, fsub([], a1)) }                                   # a0 - a1*u
fn gnorm(a: G2) : List<Int> = match a { G2(a0, a1) => fsub(fmul(a0, a0), fmul([7], fmul(a1, a1))) }     # a*conj(a) = a0^2 - 7*a1^2 (base field)
fn ginv2(a: G2) : G2 = gscale2(gconj(a), finv(gnorm(a)))                                                # a^-1 = conj(a)/norm
fn gpow2(a: G2, e: Int) : G2 = if e <= 0 then G2([1], []) else (if e % 2 == 0 then let h : G2 = gpow2(a, e / 2) in gmul2(h, h) else gmul2(a, gpow2(a, e - 1)))
fn poly_eval_g(coeffs: List<List<Int>>, z: G2) : G2 = match coeffs { [] => G2([], []); [c, ...r] => gadd2(emb(c), gmul2(z, poly_eval_g(r, z))) }   # eval a base-field poly at z in F_{p^2}
# (an imaginary-part-zero "anti-smuggling" guard was removed here: it was never wired into
# verify, and it is unnecessary — the trace openings are base-field BY TYPE (List<Int>) and
# the OOD evals are DEEP-bound to the committed base-field columns, so nothing can be smuggled
# in an imaginary part. An auditor should still confirm this. (Was dead code; removed for honesty.))
# --- B3: the grand-product Z column (F_{p^2}; interpolation splits real/imag since it
# is linear). Z_0=1; Z_{i+1}=Z_i * num_i/den_i with num=prod(val+beta*id+gamma_p),
# den=prod(val+beta*sigma+gamma_p) over the 3 columns. Telescopes to 1 iff every wire
# carries a single value (the copy constraint). perm_factor takes BASE-field val+id.
fn reals(zs: List<G2>) : List<List<Int>> = match zs { [] => []; [G2(a0, a1), ...r] => [a0] ++ reals(r) }
fn imags(zs: List<G2>) : List<List<Int>> = match zs { [] => []; [G2(a0, a1), ...r] => [a1] ++ imags(r) }
fn poly_eval_g2(zr: List<List<Int>>, zi: List<List<Int>>, z: G2) : G2 =
  match zr { [] => G2([], []); [cr, ...rr] => match zi { [] => G2([], []); [ci, ...ri] => gadd2(G2(cr, ci), gmul2(z, poly_eval_g2(rr, ri, z))) } }
fn eval_g2_on_dom(zr: List<List<Int>>, zi: List<List<Int>>, dom: List<List<Int>>) : List<G2> =
  match dom { [] => []; [x, ...r] => [G2(poly_eval_b(zr, x), poly_eval_b(zi, x))] ++ eval_g2_on_dom(zr, zi, r) }
fn perm_factor(val: List<Int>, idv: List<Int>, beta: G2, gam: G2) : G2 = gadd2(gadd2(emb(val), gmul2(beta, emb(idv))), gam)
fn perm_num(lv: List<Int>, rv: List<Int>, ov: List<Int>, i: Int, n: Int, beta: G2, gam: G2) : G2 =
  gmul2(perm_factor(lv, glit(i), beta, gam), gmul2(perm_factor(rv, glit(n + i), beta, gam), perm_factor(ov, glit(2 * n + i), beta, gam)))
fn perm_den(lv: List<Int>, rv: List<Int>, ov: List<Int>, cells: List<Pair<Int, Int>>, i: Int, n: Int, beta: G2, gam: G2) : G2 =
  gmul2(perm_factor(lv, glit(sigma(i, cells)), beta, gam), gmul2(perm_factor(rv, glit(sigma(n + i, cells)), beta, gam), perm_factor(ov, glit(sigma(2 * n + i, cells)), beta, gam)))
fn z_build(lvals: List<List<Int>>, rvals: List<List<Int>>, ovals: List<List<Int>>, cells: List<Pair<Int, Int>>, beta: G2, gam: G2, zcur: G2, i: Int, n: Int) : List<G2> =
  if i >= n then [] else
    let num : G2 = perm_num(wnth(lvals, i), wnth(rvals, i), wnth(ovals, i), i, n, beta, gam) in
    let den : G2 = perm_den(wnth(lvals, i), wnth(rvals, i), wnth(ovals, i), cells, i, n, beta, gam) in
    [zcur] ++ z_build(lvals, rvals, ovals, cells, beta, gam, gmul2(zcur, gmul2(num, ginv2(den))), i + 1, n)
fn z_final(lvals: List<List<Int>>, rvals: List<List<Int>>, ovals: List<List<Int>>, cells: List<Pair<Int, Int>>, beta: G2, gam: G2, zcur: G2, i: Int, n: Int) : G2 =
  if i >= n then zcur else
    let num : G2 = perm_num(wnth(lvals, i), wnth(rvals, i), wnth(ovals, i), i, n, beta, gam) in
    let den : G2 = perm_den(wnth(lvals, i), wnth(rvals, i), wnth(ovals, i), cells, i, n, beta, gam) in
    z_final(lvals, rvals, ovals, cells, beta, gam, gmul2(zcur, gmul2(num, ginv2(den))), i + 1, n)
fn pf(valz: G2, idz: G2, beta: G2, gam: G2) : G2 = gadd2(gadd2(valz, gmul2(beta, idz)), gam)   # F_{p^2} factor (verifier, at z)
fn beta_p_of(ts: List<Int>) : G2 = G2(lane0(hashg(ts, glit(221))), lane0(hashg(ts, glit(222))))
fn gam_p_of(ts: List<Int>) : G2 = G2(lane0(hashg(ts, glit(223))), lane0(hashg(ts, glit(224))))
fn alpha_of(ts: List<Int>) : G2 = G2(lane0(hashg(ts, glit(231))), lane0(hashg(ts, glit(232))))
fn emb(x: List<Int>) : G2 = G2(x, [])
fn embed_cw(cw: List<List<Int>>) : List<G2> = match cw { [] => []; [x, ...r] => [emb(x)] ++ embed_cw(r) }
fn lhash(leaf: G2) : List<Int> = match leaf { G2(c0, c1) => hashg(hashg(glit(7), c0), c1) }
fn nth2(xs: List<G2>, i: Int) : G2 = match xs { [] => G2([], []); [h, ...t] => if i == 0 then h else nth2(t, i - 1) }
fn next_pow2(n: Int, p: Int) : Int = if p >= n then p else next_pow2(n, p * 2)
fn leaf_hashes_g(cw: List<G2>) : List<List<Int>> = match cw { [] => []; [x, ...r] => [lhash(x)] ++ leaf_hashes_g(r) }
fn append_zeros_g(xs: List<List<Int>>, k: Int) : List<List<Int>> = if k <= 0 then xs else append_zeros_g(xs ++ [glit(0)], k - 1)
fn pad_pow2_g(xs: List<List<Int>>) : List<List<Int>> = let n : Int = llen(xs) in append_zeros_g(xs, next_pow2(n, 1) - n)
fn level_up_g(xs: List<List<Int>>) : List<List<Int>> = match xs { [] => []; [a, ...rest] => match rest { [] => [a]; [b, ...r2] => [hashg(a, b)] ++ level_up_g(r2) } }
fn root_of_g(xs: List<List<Int>>) : List<Int> = match xs { [] => []; [a, ...rest] => match rest { [] => a; _ => root_of_g(level_up_g(xs)) } }
fn merkle_root_g(cw: List<G2>) : List<Int> = root_of_g(pad_pow2_g(leaf_hashes_g(cw)))
fn path_of_g(xs: List<List<Int>>, index: Int) : List<List<Int>> = match xs { [] => []; [a, ...rest] => match rest { [] => []; _ => let sib : List<Int> = if index % 2 == 0 then wnth(xs, index + 1) else wnth(xs, index - 1) in [sib] ++ path_of_g(level_up_g(xs), index / 2) } }
fn merkle_path_g(cw: List<G2>, index: Int) : List<List<Int>> = path_of_g(pad_pow2_g(leaf_hashes_g(cw)), index)
fn fold_path_g(h: List<Int>, index: Int, path: List<List<Int>>) : List<Int> = match path { [] => h; [s, ...rest] => let up : List<Int> = if index % 2 == 0 then hashg(h, s) else hashg(s, h) in fold_path_g(up, index / 2, rest) }
fn merkle_verify_g(leaf: G2, index: Int, path: List<List<Int>>, root: List<Int>) : Bool = bn_eq(fold_path_g(lhash(leaf), index, path), root)
fn fold_pair2(fx: G2, fmx: G2, x: List<Int>, beta: G2, finv2: List<Int>) : G2 =
  let even : G2 = gscale2(gadd2(fx, fmx), finv2) in let odd : G2 = gscale2(gsub2(fx, fmx), finv(fmul([2], x))) in gadd2(even, gmul2(beta, odd))
fn fold_at2(cw: List<G2>, dom: List<List<Int>>, beta: G2, finv2: List<Int>, i: Int, half: Int) : List<G2> =
  if i >= half then [] else [fold_pair2(nth2(cw, i), nth2(cw, i + half), wnth(dom, i), beta, finv2)] ++ fold_at2(cw, dom, beta, finv2, i + 1, half)
# --- statement binding: a Poseidon digest over the gate list ------------------
# The FS transcript is SEEDED by this digest, so every FS challenge (the FRI fold
# betas and the query positions) is a deterministic function of the statement.
# gate_dig absorbs each gate's variant TAG (1..6, leading, for domain separation),
# its wire indices via glit (injective for indices < ~2^48 — true for every gate
# count), and — for GConst — the constant VALUE raw (full-width List<Int> field
# element, NOT routed through glit, so the claimed result R is captured at the full
# 2^64 width). The digest is WITNESS-INDEPENDENT: only public opcodes, wire indices,
# and constants are absorbed; GHint carries only its wire index (never the hint
# value), and the private witness `w` is never passed in. Under the current claim
# builders (build_claim / build_claim_m) the only constant in the gate list is the
# claimed result R (the last GConst), so the digest binds circuit structure + R
# without absorbing private CLI inputs (those stay in the witness, never as gates).
# glit(0) trims to [] (the field-zero element) — a valid hashg lane; the leading
# per-gate tag still separates distinct gate lists (Poseidon collision-resistance).
fn gate_dig(g: Gate, acc: List<Int>) : List<Int> = match g {
  GConst(o, c)  => hashg(hashg(hashg(acc, glit(1)), glit(o)), c);
  GAdd(o, a, b) => hashg(hashg(hashg(hashg(acc, glit(2)), glit(o)), glit(a)), glit(b));
  GSub(o, a, b) => hashg(hashg(hashg(hashg(acc, glit(3)), glit(o)), glit(a)), glit(b));
  GMul(o, a, b) => hashg(hashg(hashg(hashg(acc, glit(4)), glit(o)), glit(a)), glit(b));
  GHint(o)      => hashg(hashg(acc, glit(5)), glit(o));
  GEqZero(a)    => hashg(hashg(acc, glit(6)), glit(a)) }
fn circuit_digest(gates: List<Gate>, acc: List<Int>) : List<Int> = match gates { [] => acc; [g, ...rest] => circuit_digest(rest, gate_dig(g, acc)) }
# 2718281 = a fixed domain-separation tag (distinct from the [] seed the FRI-root
# chain would otherwise start from). NOTE: protocol params (field, coset generator
# 7, blowup 16, fold-stop 8, query count 64, 12-bit grind) are NOT in the digest —
# they are compile-time, version-pinned constants the future TIER-1 independent
# verifier must agree on out of band; they are not transcript-bound.
# The digest seed now also binds the PROTOCOL PARAMETERS (coset generator 7, blowup
# fri_dsize(1)=32, fold-stop fri_final(0)=8, query count fri_queries(0)=82, grind bits
# 12) — so a verifier instantiated with mismatched params derives different challenges
# (parameter-substitution is transcript-enforced, closing one of the two FS-PARTIAL gaps).
fn stmt_seed_of(gates: List<Gate>) : List<Int> = circuit_digest(gates, hashg(hashg(hashg(hashg(hashg(glit(2718281), glit(7)), glit(fri_dsize(1))), glit(fri_final(0))), glit(fri_queries(0))), glit(12)))
# the FRI fold challenge beta, derived from the running transcript seed (statement +
# all preceding layer roots) — NOT from the bare layer root as before.
fn beta_of_seed_g(tseed: List<Int>) : G2 = G2(lane0(hashg(tseed, glit(101))), lane0(hashg(tseed, glit(102))))
# --- memoized Merkle tree: build every level ONCE, read roots/paths from it ----
# Query verification used to recompute pad_pow2_g(leaf_hashes_g(cw)) and rebuild
# every level per query (merkle_path_g) — O(queries · tree). Instead build the full
# tree (list of levels, level 0 = padded leaf hashes, last = [root]) once per FRI
# layer, store it in the Layer, and pull sibling paths straight out. Byte-identical
# (same hashes), just not recomputed. This unblocks raising the FRI query count.
fn wnth3(xs: List<List<List<Int>>>, i: Int) : List<List<Int>> = match xs { [] => []; [x, ...r] => if i == 0 then x else wnth3(r, i - 1) }
fn l3len(xs: List<List<List<Int>>>) : Int = match xs { [] => 0; [x, ...r] => 1 + l3len(r) }
fn build_levels_g(level: List<List<Int>>, acc: List<List<List<Int>>>) : List<List<List<Int>>> =
  if llen(level) <= 1 then acc ++ [level] else build_levels_g(level_up_g(level), acc ++ [level])
fn merkle_levels_g(cw: List<G2>) : List<List<List<Int>>> = build_levels_g(pad_pow2_g(leaf_hashes_g(cw)), [])
fn root_of_levels(levels: List<List<List<Int>>>) : List<Int> = match wnth3(levels, l3len(levels) - 1) { [] => []; [r, ...t] => r }
fn path_of_levels(levels: List<List<List<Int>>>, li: Int, index: Int) : List<List<Int>> =
  if li >= l3len(levels) - 1 then []
  else let level : List<List<Int>> = wnth3(levels, li) in
       let sib : List<Int> = if index % 2 == 0 then wnth(level, index + 1) else wnth(level, index - 1) in
       [sib] ++ path_of_levels(levels, li + 1, index / 2)
fn merkle_path_levels(levels: List<List<List<Int>>>, index: Int) : List<List<Int>> = path_of_levels(levels, 0, index)
type Layer = | Layer(List<G2>, List<List<Int>>, List<Int>, G2, List<List<List<Int>>>)
# tseed is threaded through the fold: tseed -> hashg(tseed, root_i) before each
# fold, and beta_i is derived from that updated seed. So beta_i depends on the
# statement seed AND every preceding layer root (fixing both the prior absence of
# statement-binding and the prior absence of cross-layer root chaining). The SAME
# beta value is stored in the Layer and used in fold_at2 (computed once), so the
# self-check (verify_query_g reads the stored beta) stays consistent by construction.
fn commit_g(cw: List<G2>, dom: List<List<Int>>, acc: List<Layer>, tseed: List<Int>, finv2: List<Int>) : (List<Layer>, List<G2>) =
  if len(cw) <= fri_final(0) then (acc, cw)
  else let levels : List<List<List<Int>>> = merkle_levels_g(cw) in let root : List<Int> = root_of_levels(levels) in
    let tseed2 : List<Int> = hashg(tseed, root) in
    let beta : G2 = beta_of_seed_g(tseed2) in let half : Int = len(cw) / 2 in
    commit_g(fold_at2(cw, dom, beta, finv2, 0, half), sqd(dom, 0, half), acc ++ [Layer(cw, dom, root, beta, levels)], tseed2, finv2)
# LOAD-BEARING INVARIANT: transcript_seed_g(layers, stmt_seed) MUST equal the final
# tseed threaded through commit_g — identical hashg(.,root) chaining seeded by
# stmt_seed, in layer (= commit) order. This is the exact derivation the future
# TIER-1 independent verifier will re-derive the betas and query positions from; if
# these two ever diverge, the prover would sample queries from a different seed than
# it folded under. (Defensive alternative: have commit_g return the final tseed.)
fn transcript_seed_g(layers: List<Layer>, acc: List<Int>) : List<Int> = match layers { [] => acc; [Layer(cw, dom, root, beta, levels), ...rest] => transcript_seed_g(rest, hashg(acc, root)) }
fn q_low(h: List<Int>, dsize: Int) : Int = match h { [] => 0; [x, ...t] => x % dsize }
# queries WITHOUT replacement: re-draw on a collision (fresh counter) until `count`
# DISTINCT positions, so the FRI soundness gets the full `count` independent tests (no
# wasted repeats eroding the razor-thin 68+12 margin). Deterministic: prover + verifier
# derive the identical set. Terminates since count (82) << dsize (=32N).
fn imember(x: Int, xs: List<Int>) : Bool = match xs { [] => false; [h, ...t] => if h == x then true else imember(x, t) }
fn sample_distinct(seed: List<Int>, need: Int, ctr: Int, acc: List<Int>, dsize: Int) : List<Int> =
  if need <= 0 then acc
  else if lcnt(acc) >= dsize then acc                              # all dsize positions collected (tiny circuits where count > dsize) -> stop
  else let q : Int = q_low(hashg(seed, glit(ctr)), dsize) in
       if imember(q, acc) then sample_distinct(seed, need, ctr + 1, acc, dsize)
       else sample_distinct(seed, need - 1, ctr + 1, acc ++ [q], dsize)
fn sample_queries_g(seed: List<Int>, count: Int, dsize: Int) : List<Int> = sample_distinct(seed, count, 1, [], dsize)
# --- grinding (proof-of-work on the Fiat-Shamir query seed) -------------------
# The prover must find a nonce whose hash with the transcript seed clears the low
# G_BITS bits (here 12). An adversary trying to grind a favorable set of query
# positions must therefore redo 2^12 hashing per attempt — adding 12 bits to the
# query-phase soundness (the standard STARK trick; production uses 20-30 bits).
# Two-level search keeps recursion depth bounded (~chunk + #chunks), so neither the
# interpreter's limit nor the native C stack is at risk.
fn pow_ok(h: List<Int>) : Bool = match trim(h) { [] => true; [x, ...t] => x % 4096 == 0 }   # 12-bit proof-of-work (2^12=4096): the FS query seed's low 12 bits must be 0
fn grind_in(seed: List<Int>, base: Int, i: Int) : Int =
  if i >= 64 then 0 - 1 else (if pow_ok(hashg(seed, glit(base * 64 + i))) then base * 64 + i else grind_in(seed, base, i + 1))
fn grind_out(seed: List<Int>, base: Int) : Int = let r : Int = grind_in(seed, base, 0) in if r >= 0 then r else grind_out(seed, base + 1)
fn grind(seed: List<Int>) : Int = grind_out(seed, 0)
fn next_val2(rest: List<Layer>, final: List<G2>, j: Int) : G2 = match rest { [] => nth2(final, j); [Layer(cw, dom, root, beta, levels), ...more] => nth2(cw, j) }
fn verify_query_g(layers: List<Layer>, final: List<G2>, p: Int, finv2: List<Int>) : Bool =
  match layers { [] => true;
    [Layer(cw, dom, root, beta, levels), ...rest] =>
      let half : Int = len(cw) / 2 in let j : Int = p % half in
      let lx : G2 = nth2(cw, j) in let lmx : G2 = nth2(cw, j + half) in
      let ok1 : Bool = merkle_verify_g(lx, j, merkle_path_levels(levels, j), root) in
      let ok2 : Bool = merkle_verify_g(lmx, j + half, merkle_path_levels(levels, j + half), root) in
      let folded : G2 = fold_pair2(lx, lmx, wnth(dom, j), beta, finv2) in
      if ok1 then if ok2 then if geq2(folded, next_val2(rest, final, j)) then verify_query_g(rest, final, j, finv2) else false else false else false }
fn count_catches_g(layers: List<Layer>, final: List<G2>, qs: List<Int>, finv2: List<Int>) : Int =
  match qs { [] => 0; [p, ...rest] => (if verify_query_g(layers, final, p, finv2) then 0 else 1) + count_catches_g(layers, final, rest, finv2) }
fn all_eq2(cw: List<G2>, x: G2) : Bool = match cw { [] => true; [y, ...r] => if geq2(y, x) then all_eq2(r, x) else false }
fn is_const2(cw: List<G2>) : Bool = match cw { [] => true; [x, ...r] => all_eq2(r, x) }
fn blind_g(cw: List<G2>, coeffs: List<List<Int>>, dom: List<List<Int>>, i: Int) : List<G2> =
  if i >= len(cw) then [] else [gadd2(nth2(cw, i), emb(poly_eval_b(coeffs, wnth(dom, i))))] ++ blind_g(cw, coeffs, dom, i + 1)
fn prove_stark(gates: List<Gate>, w: List<List<Int>>, seed: Int) : Bool =
  let stmt_seed : List<Int> = stmt_seed_of(gates) in                     # bind the statement (circuit + R) into the transcript
  let ecw : List<G2> = blind_g(embed_cw(q_cw(gates, w)), rand_coeffs(seed, 0, 16), fri_coset(ng(gates)), 0) in
  match commit_g(ecw, fri_coset(ng(gates)), [], stmt_seed, finv([2])) { (layers, final) =>
    let base_seed : List<Int> = transcript_seed_g(layers, stmt_seed) in  # == the final tseed from commit_g (see invariant above)
    let nz : Int = grind(base_seed) in                                   # proof-of-work: 12 bits
    let ground : List<Int> = hashg(base_seed, glit(nz)) in               # the PoW-cleared query seed
    let faults : Int = count_catches_g(layers, final, sample_queries_g(ground, fri_queries(ng(gates)), fri_dsize(ng(gates))), finv([2])) in
    is_const2(final) && faults == 0 && pow_ok(ground) }
fn stark_root(gates: List<Gate>, w: List<List<Int>>, seed: Int) : List<Int> =
  merkle_root_g(blind_g(embed_cw(q_cw(gates, w)), rand_coeffs(seed, 0, 16), fri_coset(ng(gates)), 0))

# === TIER-1 (WIP, NOT YET SHIPPED): an INDEPENDENT verify(statement, proof) ====
# Splits the prover from the verifier. verify RE-DERIVES every Fiat-Shamir
# challenge — stmt_seed, the fold betas, the grind, the query positions — from the
# PUBLIC gates + the proof's Merkle roots; it never reads a stored beta and never
# sees the witness. This is the SCAFFOLDING (challenge re-derivation + opening
# checks). *** IT IS NOT YET SOUNDNESS ***: verify checks only that a low-degree
# codeword was committed and that the openings are Merkle/fold-consistent — it does
# NOT recompute G/Z_H from the gates, so a malicious prover can commit ANY low-degree
# codeword (e.g. P=0) and be ACCEPTed regardless of the statement (see prove_evil
# below — an executable demonstration of the gap). Closing it needs TIER-1 part 2:
# a trace commitment + the OOD/DEEP quotient identity + a copy/permutation argument.
type QOpen = | QOpen(G2, G2, List<List<Int>>, List<List<Int>>)            # one query, one layer: lx, lmx, path_lx, path_lmx
type Proof = | Proof(List<List<Int>>, List<G2>, Int, List<List<QOpen>>)   # roots, final, nonce, openings[query][layer]
fn fri_layers(d: Int) : Int = ilog2(fri_dsize(d) / fri_final(0))         # #FRI layers = log2(16N/8) = log2(2N)
fn qopen_len(xs: List<QOpen>) : Int = match xs { [] => 0; [x, ...r] => 1 + qopen_len(r) }
fn openings_len(xs: List<List<QOpen>>) : Int = match xs { [] => 0; [x, ...r] => 1 + openings_len(r) }
fn roots_of(layers: List<Layer>) : List<List<Int>> = match layers { [] => []; [Layer(cw, dom, root, beta, levels), ...rest] => [root] ++ roots_of(rest) }
fn build_gates(b: Build) : List<Gate> = match b { Build(n, gs, w) => gs }
fn build_wit(b: Build) : List<List<Int>> = match b { Build(n, gs, w) => w }
# --- prover: emit a Proof (roots + per-query openings, paths from stored levels) --
fn extract_query(layers: List<Layer>, p: Int) : List<QOpen> =
  match layers { [] => [];
    [Layer(cw, dom, root, beta, levels), ...rest] =>
      let half : Int = len(cw) / 2 in let j : Int = p % half in
      [QOpen(nth2(cw, j), nth2(cw, j + half), merkle_path_levels(levels, j), merkle_path_levels(levels, j + half))] ++ extract_query(rest, j) }
fn extract_all(layers: List<Layer>, queries: List<Int>) : List<List<QOpen>> =
  match queries { [] => []; [p, ...rest] => [extract_query(layers, p)] ++ extract_all(layers, rest) }
fn prove_to_proof(gates: List<Gate>, w: List<List<Int>>, seed: Int) : Proof =
  let stmt_seed : List<Int> = stmt_seed_of(gates) in
  let ecw : List<G2> = blind_g(embed_cw(q_cw(gates, w)), rand_coeffs(seed, 0, 16), fri_coset(ng(gates)), 0) in
  match commit_g(ecw, fri_coset(ng(gates)), [], stmt_seed, finv([2])) { (layers, final) =>
    let base_seed : List<Int> = transcript_seed_g(layers, stmt_seed) in
    let nz : Int = grind(base_seed) in
    let ground : List<Int> = hashg(base_seed, glit(nz)) in
    let queries : List<Int> = sample_queries_g(ground, fri_queries(ng(gates)), fri_dsize(ng(gates))) in
    Proof(roots_of(layers), final, nz, extract_all(layers, queries)) }
# --- verifier: re-derive ALL challenges from public gates + proof.roots --------
fn rederive_betas(roots: List<List<Int>>, tseed: List<Int>) : List<G2> =
  match roots { [] => []; [root, ...rest] => let ts2 : List<Int> = hashg(tseed, root) in [beta_of_seed_g(ts2)] ++ rederive_betas(rest, ts2) }
fn seed_from_roots(roots: List<List<Int>>, tseed: List<Int>) : List<Int> =
  match roots { [] => tseed; [root, ...rest] => seed_from_roots(rest, hashg(tseed, root)) }
fn build_doms(dom: List<List<Int>>, count: Int) : List<List<List<Int>>> =
  if count <= 0 then [] else [dom] ++ build_doms(sqd(dom, 0, llen(dom) / 2), count - 1)
# The fold target of layer i lands at index j_i in layer i+1's codeword, which is
# EITHER that layer's opened lx (if j_i < half_{i+1}) OR its lmx — and the SAME
# object is Merkle-verified at layer i+1, so the chain is airtight across the split.
fn vq(oq: List<QOpen>, roots: List<List<Int>>, betas: List<G2>, doms: List<List<List<Int>>>, final: List<G2>, p: Int, finv2: List<Int>) : Bool =
  match oq { [] => true;
    [QOpen(lx, lmx, plx, plmx), ...orest] =>
      match roots { [] => false; [root, ...rrest] =>
      match betas { [] => false; [beta, ...brest] =>
      match doms { [] => false; [dom, ...drest] =>
        let half : Int = llen(dom) / 2 in let j : Int = p % half in
        let next_half : Int = match drest { [] => 0; [nd, ...nn] => llen(nd) / 2 } in
        let nextv : G2 = match orest { [] => nth2(final, j); [QOpen(nlx, nlmx, np1, np2), ...more] => if j < next_half then nlx else nlmx } in
        let ok1 : Bool = merkle_verify_g(lx, j, plx, root) in
        let ok2 : Bool = merkle_verify_g(lmx, j + half, plmx, root) in
        let folded : G2 = fold_pair2(lx, lmx, wnth(dom, j), beta, finv2) in
        if ok1 then if ok2 then if geq2(folded, nextv) then vq(orest, rrest, brest, drest, final, j, finv2) else false else false else false } } } }
fn verify_queries(openings: List<List<QOpen>>, roots: List<List<Int>>, betas: List<G2>, doms: List<List<List<Int>>>, final: List<G2>, queries: List<Int>, lyrs: Int, finv2: List<Int>) : Bool =
  match openings { [] => match queries { [] => true; _ => false };
    [oq, ...orest] => match queries { [] => false; [p, ...qrest] =>
      if qopen_len(oq) == lyrs then (if vq(oq, roots, betas, doms, final, p, finv2) then verify_queries(orest, roots, betas, doms, final, qrest, lyrs, finv2) else false) else false } }
fn verify(gates: List<Gate>, proof: Proof) : Bool =
  match proof { Proof(roots, final, nonce, openings) =>
    let n : Int = ng(gates) in let lyrs : Int = fri_layers(n) in
    let stmt_seed : List<Int> = stmt_seed_of(gates) in
    let betas : List<G2> = rederive_betas(roots, stmt_seed) in
    let base_seed : List<Int> = seed_from_roots(roots, stmt_seed) in
    let ground : List<Int> = hashg(base_seed, glit(nonce)) in
    let doms : List<List<List<Int>>> = build_doms(fri_coset(n), lyrs) in
    let queries : List<Int> = sample_queries_g(ground, fri_queries(n), fri_dsize(n)) in
    (llen(roots) == lyrs) && (len(final) == fri_final(0)) && (openings_len(openings) == fri_queries(n))
      && pow_ok(ground) && is_const2(final) && verify_queries(openings, roots, betas, doms, final, queries, lyrs, finv([2])) }
# --- the HONEST GAP, made executable: a malicious prover commits P=0 (low-degree,
# unrelated to the gates or to ANY witness); verify ACCEPTs it for any statement.
# THIS is why the scaffolding above is not yet soundness — TIER-1 part 2 closes it.
fn zeros_cw(k: Int) : List<G2> = if k <= 0 then [] else [emb(glit(0))] ++ zeros_cw(k - 1)
fn prove_evil(gates: List<Gate>) : Proof =
  let stmt_seed : List<Int> = stmt_seed_of(gates) in
  match commit_g(zeros_cw(fri_dsize(ng(gates))), fri_coset(ng(gates)), [], stmt_seed, finv([2])) { (layers, final) =>
    let base_seed : List<Int> = transcript_seed_g(layers, stmt_seed) in
    let nz : Int = grind(base_seed) in
    let ground : List<Int> = hashg(base_seed, glit(nz)) in
    let queries : List<Int> = sample_queries_g(ground, fri_queries(ng(gates)), fri_dsize(ng(gates))) in
    Proof(roots_of(layers), final, nz, extract_all(layers, queries)) }
fn tamper_nonce(proof: Proof) : Proof = match proof { Proof(roots, final, nonce, openings) => Proof(roots, final, nonce + 1, openings) }

# === TIER-1 PART 2 (WIP): SOUND prover/verifier — ties Q to the gate constraints
# Closes the P=0 gap. Commit the trace (l,r,o) AND the quotient Q (UNBLINDED — ZK is
# SUSPENDED on this path: witness opened in clear). Draw an out-of-domain z in F_{p^2}
# AFTER the trace commitment; prover sends l(z),r(z),o(z),Q(z); verifier checks the
# constraint identity Q(z)*Z_H(z) == G(z) in F_{p^2}; the DEEP quotients (T(x)-T(z))/(x-z)
# for T in {l,r,o,Q} are batched with an FS gamma and run through the EXISTING FRI, which
# degree-bounds all four columns AND binds the sent z-evals to the committed trees.
# WHAT THIS PROVES: every row of the committed trace satisfies its per-row gate, and R =
# the asserted output row. WHAT IT DOES NOT: inter-row WIRE consistency (B3, copy/perm,
# not built) — a prover can still thread inconsistent values across rows. NOT out of
# research grade (B3 + external audit remain); NOT zero-knowledge on this path.
type TOpen = | TOpen(List<Int>, List<Int>, List<Int>, List<Int>, List<List<Int>>, List<Int>, List<Int>, List<Int>, List<Int>, List<List<Int>>)
type ProofS = | ProofS(List<Int>, G2, G2, G2, G2, List<List<Int>>, List<G2>, Int, List<List<QOpen>>, List<TOpen>)
fn ood_of(ts: List<Int>) : G2 = G2(lane0(hashg(ts, glit(201))), lane0(hashg(ts, glit(202))))
fn gamma_of(ts: List<Int>) : G2 = G2(lane0(hashg(ts, glit(211))), lane0(hashg(ts, glit(212))))
fn absorb_g2(acc: List<Int>, g: G2) : List<Int> = match g { G2(a0, a1) => hashg(hashg(acc, a0), a1) }
fn ts_with_ood(ts1: List<Int>, lz: G2, rz: G2, oz: G2, qz: G2) : List<Int> = absorb_g2(absorb_g2(absorb_g2(absorb_g2(ts1, lz), rz), oz), qz)
fn zh_g(z: G2, n: Int) : G2 = gsub2(gpow2(z, n), G2([1], []))
fn g_at_z(pc: List<List<List<Int>>>, lz: G2, rz: G2, oz: G2, z: G2) : G2 =
  let va : G2 = poly_eval_g(wnth3(pc, 0), z) in let vm : G2 = poly_eval_g(wnth3(pc, 1), z) in
  let vs : G2 = poly_eval_g(wnth3(pc, 2), z) in let vc : G2 = poly_eval_g(wnth3(pc, 3), z) in
  let vqe : G2 = poly_eval_g(wnth3(pc, 4), z) in let vk : G2 = poly_eval_g(wnth3(pc, 5), z) in
  gadd2(gmul2(va, gsub2(oz, gadd2(lz, rz))), gadd2(gmul2(vm, gsub2(oz, gmul2(lz, rz))), gadd2(gmul2(vs, gsub2(oz, gsub2(lz, rz))), gadd2(gmul2(vc, gsub2(oz, vk)), gmul2(vqe, lz)))))
fn deep_batch(li: List<Int>, ri: List<Int>, oi: List<Int>, qi: List<Int>, xi: List<Int>, lz: G2, rz: G2, oz: G2, qz: G2, z: G2, gam: G2) : G2 =
  let den : G2 = ginv2(gsub2(emb(xi), z)) in
  let qdq : G2 = gmul2(gsub2(emb(qi), qz), den) in let qdl : G2 = gmul2(gsub2(emb(li), lz), den) in
  let qdr : G2 = gmul2(gsub2(emb(ri), rz), den) in let qdo : G2 = gmul2(gsub2(emb(oi), oz), den) in
  let g2 : G2 = gmul2(gam, gam) in let g3 : G2 = gmul2(g2, gam) in
  gadd2(qdq, gadd2(gmul2(gam, qdl), gadd2(gmul2(g2, qdr), gmul2(g3, qdo))))
fn comb_leaf(li: List<Int>, ri: List<Int>, oi: List<Int>, qi: List<Int>) : List<Int> = hashg(hashg(hashg(li, ri), oi), qi)
fn trace_leaf_list(lcw: List<List<Int>>, rcw: List<List<Int>>, ocw: List<List<Int>>, qcw: List<List<Int>>, i: Int, m: Int) : List<List<Int>> =
  if i >= m then [] else [comb_leaf(wnth(lcw, i), wnth(rcw, i), wnth(ocw, i), wnth(qcw, i))] ++ trace_leaf_list(lcw, rcw, ocw, qcw, i + 1, m)
fn build_b(lcw: List<List<Int>>, rcw: List<List<Int>>, ocw: List<List<Int>>, qcw: List<List<Int>>, coset: List<List<Int>>, lz: G2, rz: G2, oz: G2, qz: G2, z: G2, gam: G2, i: Int, m: Int) : List<G2> =
  if i >= m then [] else [deep_batch(wnth(lcw, i), wnth(rcw, i), wnth(ocw, i), wnth(qcw, i), wnth(coset, i), lz, rz, oz, qz, z, gam)] ++ build_b(lcw, rcw, ocw, qcw, coset, lz, rz, oz, qz, z, gam, i + 1, m)
fn merkle_verify_h(leaf: List<Int>, index: Int, path: List<List<Int>>, root: List<Int>) : Bool = bn_eq(fold_path_g(leaf, index, path), root)
fn tlen(xs: List<TOpen>) : Int = match xs { [] => 0; [x, ...r] => 1 + tlen(r) }
fn extract_trace1(lcw: List<List<Int>>, rcw: List<List<Int>>, ocw: List<List<Int>>, qcw: List<List<Int>>, tlevels: List<List<List<Int>>>, p: Int, m: Int) : TOpen =
  let half : Int = m / 2 in let j : Int = p % half in
  TOpen(wnth(lcw, j), wnth(rcw, j), wnth(ocw, j), wnth(qcw, j), merkle_path_levels(tlevels, j),
        wnth(lcw, j + half), wnth(rcw, j + half), wnth(ocw, j + half), wnth(qcw, j + half), merkle_path_levels(tlevels, j + half))
fn extract_traces(lcw: List<List<Int>>, rcw: List<List<Int>>, ocw: List<List<Int>>, qcw: List<List<Int>>, tlevels: List<List<List<Int>>>, queries: List<Int>, m: Int) : List<TOpen> =
  match queries { [] => []; [p, ...rest] => [extract_trace1(lcw, rcw, ocw, qcw, tlevels, p, m)] ++ extract_traces(lcw, rcw, ocw, qcw, tlevels, rest, m) }
fn prove_sound(gates: List<Gate>, w: List<List<Int>>) : ProofS =
  let n : Int = ng(gates) in let m : Int = fri_dsize(n) in let coset : List<List<Int>> = fri_coset(n) in
  let stmt : List<Int> = stmt_seed_of(gates) in
  let pc : List<List<List<Int>>> = public_cols(gates, n) in let tc : List<List<List<Int>>> = trace_cols(gates, w, n) in
  let ll : List<List<Int>> = wnth3(tc, 0) in let rr : List<List<Int>> = wnth3(tc, 1) in let oo : List<List<Int>> = wnth3(tc, 2) in
  let lcw : List<List<Int>> = eval_on_dom(ll, coset) in let rcw : List<List<Int>> = eval_on_dom(rr, coset) in let ocw : List<List<Int>> = eval_on_dom(oo, coset) in
  let qcw : List<List<Int>> = q_cw(gates, w) in
  let tlevels : List<List<List<Int>>> = build_levels_g(pad_pow2_g(trace_leaf_list(lcw, rcw, ocw, qcw, 0, m)), []) in
  let trace_root : List<Int> = root_of_levels(tlevels) in
  let ts1 : List<Int> = hashg(stmt, trace_root) in let z : G2 = ood_of(ts1) in
  let lz : G2 = poly_eval_g(ll, z) in let rz : G2 = poly_eval_g(rr, z) in let oz : G2 = poly_eval_g(oo, z) in
  let qz : G2 = gmul2(g_at_z(pc, lz, rz, oz, z), ginv2(zh_g(z, n))) in
  let ts2 : List<Int> = ts_with_ood(ts1, lz, rz, oz, qz) in let gam : G2 = gamma_of(ts2) in
  let bcw : List<G2> = build_b(lcw, rcw, ocw, qcw, coset, lz, rz, oz, qz, z, gam, 0, m) in
  match commit_g(bcw, coset, [], ts2, finv([2])) { (blayers, bfinal) =>
    let base_seed : List<Int> = transcript_seed_g(blayers, ts2) in
    let nz : Int = grind(base_seed) in let ground : List<Int> = hashg(base_seed, glit(nz)) in
    let queries : List<Int> = sample_queries_g(ground, fri_queries(n), fri_dsize(n)) in
    ProofS(trace_root, lz, rz, oz, qz, roots_of(blayers), bfinal, nz, extract_all(blayers, queries), extract_traces(lcw, rcw, ocw, qcw, tlevels, queries, fri_dsize(n))) }
fn vsq1(boq: List<QOpen>, toq: TOpen, broots: List<List<Int>>, betas: List<G2>, doms: List<List<List<Int>>>, bfinal: List<G2>, coset: List<List<Int>>, lz: G2, rz: G2, oz: G2, qz: G2, z: G2, gam: G2, trace_root: List<Int>, m: Int, p: Int, lyrs: Int, finv2: List<Int>) : Bool =
  let half : Int = m / 2 in let j : Int = p % half in
  match toq { TOpen(lj, rj, oj, qj, pj, ljh, rjh, ojh, qjh, pjh) =>
    let mk1 : Bool = merkle_verify_h(comb_leaf(lj, rj, oj, qj), j, pj, trace_root) in
    let mk2 : Bool = merkle_verify_h(comb_leaf(ljh, rjh, ojh, qjh), j + half, pjh, trace_root) in
    let bj : G2 = deep_batch(lj, rj, oj, qj, wnth(coset, j), lz, rz, oz, qz, z, gam) in
    let bjh : G2 = deep_batch(ljh, rjh, ojh, qjh, wnth(coset, j + half), lz, rz, oz, qz, z, gam) in
    let recon : Bool = match boq { [] => false; [QOpen(blx, blmx, p1, p2), ...rest] => geq2(bj, blx) && geq2(bjh, blmx) } in
    mk1 && mk2 && recon && (qopen_len(boq) == lyrs) && vq(boq, broots, betas, doms, bfinal, p, finv2) }
fn vsqs(bopen: List<List<QOpen>>, topen: List<TOpen>, broots: List<List<Int>>, betas: List<G2>, doms: List<List<List<Int>>>, bfinal: List<G2>, coset: List<List<Int>>, lz: G2, rz: G2, oz: G2, qz: G2, z: G2, gam: G2, trace_root: List<Int>, m: Int, queries: List<Int>, lyrs: Int, finv2: List<Int>) : Bool =
  match bopen { [] => match queries { [] => match topen { [] => true; _ => false }; _ => false };
    [boq, ...brest] => match topen { [] => false; [toq, ...trest] => match queries { [] => false; [p, ...qrest] =>
      if vsq1(boq, toq, broots, betas, doms, bfinal, coset, lz, rz, oz, qz, z, gam, trace_root, m, p, lyrs, finv2)
      then vsqs(brest, trest, broots, betas, doms, bfinal, coset, lz, rz, oz, qz, z, gam, trace_root, m, qrest, lyrs, finv2) else false } } }
fn verify_sound(gates: List<Gate>, proof: ProofS) : Bool =
  match proof { ProofS(trace_root, lz, rz, oz, qz, broots, bfinal, nonce, bopen, topen) =>
    let n : Int = ng(gates) in let m : Int = fri_dsize(n) in let coset : List<List<Int>> = fri_coset(n) in let lyrs : Int = fri_layers(n) in
    let stmt : List<Int> = stmt_seed_of(gates) in let pc : List<List<List<Int>>> = public_cols(gates, n) in
    let ts1 : List<Int> = hashg(stmt, trace_root) in let z : G2 = ood_of(ts1) in
    let ts2 : List<Int> = ts_with_ood(ts1, lz, rz, oz, qz) in let gam : G2 = gamma_of(ts2) in
    let betas : List<G2> = rederive_betas(broots, ts2) in let base_seed : List<Int> = seed_from_roots(broots, ts2) in
    let ground : List<Int> = hashg(base_seed, glit(nonce)) in
    let doms : List<List<List<Int>>> = build_doms(coset, lyrs) in
    let queries : List<Int> = sample_queries_g(ground, fri_queries(n), fri_dsize(n)) in
    # OOD evals l(z),r(z),o(z),Q(z) are legitimately COMPLEX (base-field polys at a complex z); no real-only
    # guard on them. The per-query trace openings are base-field by TYPE (List<Int>), and the DEEP-FRI binds
    # the sent z-evals to the committed columns, so nothing can be smuggled. The identity is the whole check.
    let id_ok : Bool = geq2(gmul2(qz, zh_g(z, n)), g_at_z(pc, lz, rz, oz, z)) in
    let struct_ok : Bool = (llen(broots) == lyrs) && (len(bfinal) == fri_final(0)) && (openings_len(bopen) == fri_queries(n)) && (tlen(topen) == fri_queries(n)) && pow_ok(ground) && is_const2(bfinal) in
    id_ok && struct_ok && vsqs(bopen, topen, broots, betas, doms, bfinal, coset, lz, rz, oz, qz, z, gam, trace_root, m, queries, lyrs, finv([2])) }
# P=0 attack against the SOUND path: commit all-zero l,r,o,Q and zero OOD evals; the
# DEEP-FRI/Merkle all pass, but the identity Q(z)*Z_H(z)==G(z) FAILS (0 != G_pub(z),
# nonzero off H because of the GConst(R) row) -> REJECT. The headline regression.
fn zeros_b(k: Int) : List<List<Int>> = if k <= 0 then [] else [glit(0)] ++ zeros_b(k - 1)
fn prove_sound_evil(gates: List<Gate>) : ProofS =
  let n : Int = ng(gates) in let m : Int = fri_dsize(n) in let coset : List<List<Int>> = fri_coset(n) in
  let stmt : List<Int> = stmt_seed_of(gates) in let z0 : List<List<Int>> = zeros_b(m) in
  let tlevels : List<List<List<Int>>> = build_levels_g(pad_pow2_g(trace_leaf_list(z0, z0, z0, z0, 0, m)), []) in
  let trace_root : List<Int> = root_of_levels(tlevels) in
  let ts1 : List<Int> = hashg(stmt, trace_root) in let z : G2 = ood_of(ts1) in
  let lz : G2 = G2([], []) in let rz : G2 = G2([], []) in let oz : G2 = G2([], []) in let qz : G2 = G2([], []) in
  let ts2 : List<Int> = ts_with_ood(ts1, lz, rz, oz, qz) in let gam : G2 = gamma_of(ts2) in
  let bcw : List<G2> = build_b(z0, z0, z0, z0, coset, lz, rz, oz, qz, z, gam, 0, m) in
  match commit_g(bcw, coset, [], ts2, finv([2])) { (blayers, bfinal) =>
    let base_seed : List<Int> = transcript_seed_g(blayers, ts2) in
    let nz : Int = grind(base_seed) in let ground : List<Int> = hashg(base_seed, glit(nz)) in
    let queries : List<Int> = sample_queries_g(ground, fri_queries(n), fri_dsize(n)) in
    ProofS(trace_root, lz, rz, oz, qz, roots_of(blayers), bfinal, nz, extract_all(blayers, queries), extract_traces(z0, z0, z0, z0, tlevels, queries, fri_dsize(n))) }
# tamper a trace opening (flip the first query's l value): the Merkle leaf no longer
# matches trace_root AND the reconstructed B no longer matches the FRI opening -> REJECT.
# Pins the trace<->FRI index alignment (the synthesis's subtlest-bug guard).
fn tamper_topen(topen: List<TOpen>) : List<TOpen> = match topen { [] => []; [TOpen(lj, rj, oj, qj, pj, ljh, rjh, ojh, qjh, pjh), ...rest] => [TOpen(fadd(lj, [1]), rj, oj, qj, pj, ljh, rjh, ojh, qjh, pjh)] ++ rest }
fn tamper_strace(proof: ProofS) : ProofS = match proof { ProofS(tr, lz, rz, oz, qz, broots, bfinal, nonce, bopen, topen) => ProofS(tr, lz, rz, oz, qz, broots, bfinal, nonce, bopen, tamper_topen(topen)) }

# === TIER-1 PART 3 (WIP): SOUND prover/verifier WITH the copy/permutation argument
# Adds the PLONK grand-product so the committed trace is a CONSISTENT wire assignment
# (one value per wire), closing the inter-row gap. Staged 3-tree commit (commit-before-
# challenge): T1{l,r,o} -> beta,gamma_p -> T2{Z} -> alpha -> T3{Q} -> z(OOD). Q combines
# the gate, recurrence, and boundary constraints with powers of alpha. DEEP-FRI batches
# {l,r,o,Q,Z} (Z bound at z AND omega*z). Verifier checks qz == combined-quotient(z).
type TOpenB = | TOpenB(List<Int>, List<Int>, List<Int>, G2, G2, List<List<Int>>, List<List<Int>>, List<List<Int>>, List<Int>, List<Int>, List<Int>, G2, G2, List<List<Int>>, List<List<Int>>, List<List<Int>>)
type ProofB3 = | ProofB3(List<Int>, List<Int>, List<Int>, G2, G2, G2, G2, G2, G2, List<List<Int>>, List<G2>, Int, List<List<QOpen>>, List<TOpenB>)
fn comb_lro(l: List<Int>, r: List<Int>, o: List<Int>) : List<Int> = hashg(hashg(l, r), o)
fn trace_leaf_lro(lcw: List<List<Int>>, rcw: List<List<Int>>, ocw: List<List<Int>>, i: Int, m: Int) : List<List<Int>> = if i >= m then [] else [comb_lro(wnth(lcw, i), wnth(rcw, i), wnth(ocw, i))] ++ trace_leaf_lro(lcw, rcw, ocw, i + 1, m)
fn tblen(xs: List<TOpenB>) : Int = match xs { [] => 0; [x, ...r] => 1 + tblen(r) }
fn absorb6(ts: List<Int>, a: G2, b: G2, c: G2, d: G2, e: G2, f: G2) : List<Int> = absorb_g2(absorb_g2(absorb_g2(absorb_g2(absorb_g2(absorb_g2(ts, a), b), c), d), e), f)
# absorb the final folded codeword into the transcript BEFORE sampling queries
# (standard BCS/ethSTARK; closes the second FS-PARTIAL gap — the query positions now
# depend on bfinal, so a prover cannot adapt the final codeword after seeing the queries).
fn absorb_final(acc: List<Int>, fin: List<G2>) : List<Int> = match fin { [] => acc; [G2(a0, a1), ...r] => absorb_final(hashg(hashg(acc, a0), a1), r) }
fn recur_at_z(pm: List<List<List<Int>>>, lz: G2, rz: G2, oz: G2, zz: G2, zwz: G2, beta: G2, gamp: G2, z: G2) : G2 =
  let id1z : G2 = poly_eval_g(wnth3(pm, 0), z) in let id2z : G2 = poly_eval_g(wnth3(pm, 1), z) in let id3z : G2 = poly_eval_g(wnth3(pm, 2), z) in
  let s1z : G2 = poly_eval_g(wnth3(pm, 3), z) in let s2z : G2 = poly_eval_g(wnth3(pm, 4), z) in let s3z : G2 = poly_eval_g(wnth3(pm, 5), z) in
  let numz : G2 = gmul2(pf(lz, id1z, beta, gamp), gmul2(pf(rz, id2z, beta, gamp), pf(oz, id3z, beta, gamp))) in
  let denz : G2 = gmul2(pf(lz, s1z, beta, gamp), gmul2(pf(rz, s2z, beta, gamp), pf(oz, s3z, beta, gamp))) in
  gsub2(gmul2(zwz, denz), gmul2(zz, numz))
fn qcombined_z(pc: List<List<List<Int>>>, pm: List<List<List<Int>>>, lz: G2, rz: G2, oz: G2, zz: G2, zwz: G2, beta: G2, gamp: G2, alpha: G2, z: G2, n: Int) : G2 =
  let izh : G2 = ginv2(zh_g(z, n)) in
  let qgate : G2 = gmul2(g_at_z(pc, lz, rz, oz, z), izh) in
  let qrec : G2 = gmul2(recur_at_z(pm, lz, rz, oz, zz, zwz, beta, gamp, z), izh) in
  let qbnd : G2 = gmul2(gsub2(zz, G2([1], [])), ginv2(gsub2(z, G2([1], [])))) in
  gadd2(qgate, gadd2(gmul2(alpha, qrec), gmul2(gmul2(alpha, alpha), qbnd)))
fn build_q_b3(pc: List<List<List<Int>>>, pm: List<List<List<Int>>>, qgatecw: List<List<Int>>, lcw: List<List<Int>>, rcw: List<List<Int>>, ocw: List<List<Int>>, zcw: List<G2>, coset: List<List<Int>>, alpha: G2, beta: G2, gamp: G2, n: Int, rot: Int, m: Int, i: Int) : List<G2> =
  if i >= m then [] else
    let x : List<Int> = wnth(coset, i) in let zhx : List<Int> = fsub(fpow_bn(x, glit(n)), [1]) in
    let lx : List<Int> = wnth(lcw, i) in let rx : List<Int> = wnth(rcw, i) in let ox : List<Int> = wnth(ocw, i) in
    let zx : G2 = nth2(zcw, i) in let zwx : G2 = nth2(zcw, (i + rot) % m) in
    let numx : G2 = gmul2(pf(emb(lx), emb(poly_eval_b(wnth3(pm, 0), x)), beta, gamp), gmul2(pf(emb(rx), emb(poly_eval_b(wnth3(pm, 1), x)), beta, gamp), pf(emb(ox), emb(poly_eval_b(wnth3(pm, 2), x)), beta, gamp))) in
    let denx : G2 = gmul2(pf(emb(lx), emb(poly_eval_b(wnth3(pm, 3), x)), beta, gamp), gmul2(pf(emb(rx), emb(poly_eval_b(wnth3(pm, 4), x)), beta, gamp), pf(emb(ox), emb(poly_eval_b(wnth3(pm, 5), x)), beta, gamp))) in
    let qrecur : G2 = gscale2(gsub2(gmul2(zwx, denx), gmul2(zx, numx)), finv(zhx)) in
    let qbound : G2 = gmul2(gsub2(zx, G2([1], [])), ginv2(gsub2(emb(x), G2([1], [])))) in
    [gadd2(emb(wnth(qgatecw, i)), gadd2(gmul2(alpha, qrecur), gmul2(gmul2(alpha, alpha), qbound)))] ++ build_q_b3(pc, pm, qgatecw, lcw, rcw, ocw, zcw, coset, alpha, beta, gamp, n, rot, m, i + 1)
fn deep_batch_b3(lj: List<Int>, rj: List<Int>, oj: List<Int>, qj: G2, zj: G2, xi: List<Int>, lz: G2, rz: G2, oz: G2, qz: G2, zz: G2, zwz: G2, z: G2, wz: G2, gam: G2) : G2 =
  let invz : G2 = ginv2(gsub2(emb(xi), z)) in let invwz : G2 = ginv2(gsub2(emb(xi), wz)) in
  let dq : G2 = gmul2(gsub2(qj, qz), invz) in let dl : G2 = gmul2(gsub2(emb(lj), lz), invz) in let dr : G2 = gmul2(gsub2(emb(rj), rz), invz) in
  let dlo : G2 = gmul2(gsub2(emb(oj), oz), invz) in let dz : G2 = gmul2(gsub2(zj, zz), invz) in let dzw : G2 = gmul2(gsub2(zj, zwz), invwz) in
  let g2 : G2 = gmul2(gam, gam) in let g3 : G2 = gmul2(g2, gam) in let g4 : G2 = gmul2(g3, gam) in let g5 : G2 = gmul2(g4, gam) in
  gadd2(dq, gadd2(gmul2(gam, dl), gadd2(gmul2(g2, dr), gadd2(gmul2(g3, dlo), gadd2(gmul2(g4, dz), gmul2(g5, dzw))))))
fn build_b_b3(lcw: List<List<Int>>, rcw: List<List<Int>>, ocw: List<List<Int>>, qcw: List<G2>, zcw: List<G2>, coset: List<List<Int>>, lz: G2, rz: G2, oz: G2, qz: G2, zz: G2, zwz: G2, z: G2, wz: G2, gam: G2, i: Int, m: Int) : List<G2> =
  if i >= m then [] else [deep_batch_b3(wnth(lcw, i), wnth(rcw, i), wnth(ocw, i), nth2(qcw, i), nth2(zcw, i), wnth(coset, i), lz, rz, oz, qz, zz, zwz, z, wz, gam)] ++ build_b_b3(lcw, rcw, ocw, qcw, zcw, coset, lz, rz, oz, qz, zz, zwz, z, wz, gam, i + 1, m)
fn extract_tb1(lcw: List<List<Int>>, rcw: List<List<Int>>, ocw: List<List<Int>>, qcw: List<G2>, zcw: List<G2>, lev1: List<List<List<Int>>>, lev2: List<List<List<Int>>>, lev3: List<List<List<Int>>>, p: Int, m: Int) : TOpenB =
  let half : Int = m / 2 in let j : Int = p % half in
  TOpenB(wnth(lcw, j), wnth(rcw, j), wnth(ocw, j), nth2(qcw, j), nth2(zcw, j), merkle_path_levels(lev1, j), merkle_path_levels(lev3, j), merkle_path_levels(lev2, j),
         wnth(lcw, j + half), wnth(rcw, j + half), wnth(ocw, j + half), nth2(qcw, j + half), nth2(zcw, j + half), merkle_path_levels(lev1, j + half), merkle_path_levels(lev3, j + half), merkle_path_levels(lev2, j + half))
fn extract_tb(lcw: List<List<Int>>, rcw: List<List<Int>>, ocw: List<List<Int>>, qcw: List<G2>, zcw: List<G2>, lev1: List<List<List<Int>>>, lev2: List<List<List<Int>>>, lev3: List<List<List<Int>>>, queries: List<Int>, m: Int) : List<TOpenB> =
  match queries { [] => []; [p, ...rest] => [extract_tb1(lcw, rcw, ocw, qcw, zcw, lev1, lev2, lev3, p, m)] ++ extract_tb(lcw, rcw, ocw, qcw, zcw, lev1, lev2, lev3, rest, m) }
fn prove_b3(gates: List<Gate>, w: List<List<Int>>) : ProofB3 =
  let n : Int = ng(gates) in let m : Int = fri_dsize(n) in let coset : List<List<Int>> = fri_coset(n) in let rot : Int = m / n in let omega : List<Int> = root_pow2(ilog2(n)) in
  let stmt : List<Int> = stmt_seed_of(gates) in let pc : List<List<List<Int>>> = public_cols(gates, n) in let pm : List<List<List<Int>>> = perm_cols(gates, n) in
  let cells : List<Pair<Int, Int>> = all_cells(gates, 0, n) in
  let lvals : List<List<Int>> = lpad(c_l(gates, w), n) in let rvals : List<List<Int>> = lpad(c_r(gates, w), n) in let ovals : List<List<Int>> = lpad(c_o(gates, w), n) in
  let ll : List<List<Int>> = icol(c_l(gates, w), n) in let rr : List<List<Int>> = icol(c_r(gates, w), n) in let oo : List<List<Int>> = icol(c_o(gates, w), n) in
  let lcw : List<List<Int>> = eval_on_dom(ll, coset) in let rcw : List<List<Int>> = eval_on_dom(rr, coset) in let ocw : List<List<Int>> = eval_on_dom(oo, coset) in
  let qgatecw : List<List<Int>> = q_cw(gates, w) in
  let lev1 : List<List<List<Int>>> = build_levels_g(pad_pow2_g(trace_leaf_lro(lcw, rcw, ocw, 0, m)), []) in let root1 : List<Int> = root_of_levels(lev1) in
  let ts1 : List<Int> = hashg(stmt, root1) in let beta : G2 = beta_p_of(ts1) in let gamp : G2 = gam_p_of(ts1) in
  let zvals : List<G2> = z_build(lvals, rvals, ovals, cells, beta, gamp, G2([1], []), 0, n) in
  let zr : List<List<Int>> = interp_n(reals(zvals), n) in let zi : List<List<Int>> = interp_n(imags(zvals), n) in
  let zcw : List<G2> = eval_g2_on_dom(zr, zi, coset) in
  let lev2 : List<List<List<Int>>> = merkle_levels_g(zcw) in let root2 : List<Int> = root_of_levels(lev2) in
  let ts2 : List<Int> = hashg(ts1, root2) in let alpha : G2 = alpha_of(ts2) in
  let qcw : List<G2> = build_q_b3(pc, pm, qgatecw, lcw, rcw, ocw, zcw, coset, alpha, beta, gamp, n, rot, m, 0) in
  let lev3 : List<List<List<Int>>> = merkle_levels_g(qcw) in let root3 : List<Int> = root_of_levels(lev3) in
  let ts3 : List<Int> = hashg(ts2, root3) in let z : G2 = ood_of(ts3) in let wz : G2 = gmul2(z, emb(omega)) in
  let lz : G2 = poly_eval_g(ll, z) in let rz : G2 = poly_eval_g(rr, z) in let oz : G2 = poly_eval_g(oo, z) in
  let zz : G2 = poly_eval_g2(zr, zi, z) in let zwz : G2 = poly_eval_g2(zr, zi, wz) in
  let qz : G2 = qcombined_z(pc, pm, lz, rz, oz, zz, zwz, beta, gamp, alpha, z, n) in
  let ts4 : List<Int> = absorb6(ts3, lz, rz, oz, qz, zz, zwz) in let gamd : G2 = gamma_of(ts4) in
  let bcw : List<G2> = build_b_b3(lcw, rcw, ocw, qcw, zcw, coset, lz, rz, oz, qz, zz, zwz, z, wz, gamd, 0, m) in
  match commit_g(bcw, coset, [], ts4, finv([2])) { (blayers, bfinal) =>
    let base_seed : List<Int> = absorb_final(transcript_seed_g(blayers, ts4), bfinal) in let nz : Int = grind(base_seed) in let ground : List<Int> = hashg(base_seed, glit(nz)) in
    let queries : List<Int> = sample_queries_g(ground, fri_queries(n), fri_dsize(n)) in
    ProofB3(root1, root2, root3, lz, rz, oz, qz, zz, zwz, roots_of(blayers), bfinal, nz, extract_all(blayers, queries), extract_tb(lcw, rcw, ocw, qcw, zcw, lev1, lev2, lev3, queries, m)) }
fn vb3_q1(boq: List<QOpen>, toq: TOpenB, root1: List<Int>, root2: List<Int>, root3: List<Int>, broots: List<List<Int>>, betas: List<G2>, doms: List<List<List<Int>>>, bfinal: List<G2>, coset: List<List<Int>>, lz: G2, rz: G2, oz: G2, qz: G2, zz: G2, zwz: G2, z: G2, wz: G2, gamd: G2, m: Int, p: Int, lyrs: Int, finv2: List<Int>) : Bool =
  let half : Int = m / 2 in let j : Int = p % half in
  match toq { TOpenB(lj, rj, oj, qj, zj, p1j, p3j, p2j, ljh, rjh, ojh, qjh, zjh, p1jh, p3jh, p2jh) =>
    let mk1 : Bool = merkle_verify_h(comb_lro(lj, rj, oj), j, p1j, root1) && merkle_verify_h(comb_lro(ljh, rjh, ojh), j + half, p1jh, root1) in
    let mk3 : Bool = merkle_verify_g(qj, j, p3j, root3) && merkle_verify_g(qjh, j + half, p3jh, root3) in
    let mk2 : Bool = merkle_verify_g(zj, j, p2j, root2) && merkle_verify_g(zjh, j + half, p2jh, root2) in
    let bj : G2 = deep_batch_b3(lj, rj, oj, qj, zj, wnth(coset, j), lz, rz, oz, qz, zz, zwz, z, wz, gamd) in
    let bjh : G2 = deep_batch_b3(ljh, rjh, ojh, qjh, zjh, wnth(coset, j + half), lz, rz, oz, qz, zz, zwz, z, wz, gamd) in
    let recon : Bool = match boq { [] => false; [QOpen(blx, blmx, pp1, pp2), ...rest] => geq2(bj, blx) && geq2(bjh, blmx) } in
    mk1 && mk3 && mk2 && recon && (qopen_len(boq) == lyrs) && vq(boq, broots, betas, doms, bfinal, p, finv2) }
fn vb3_qs(bopen: List<List<QOpen>>, topen: List<TOpenB>, root1: List<Int>, root2: List<Int>, root3: List<Int>, broots: List<List<Int>>, betas: List<G2>, doms: List<List<List<Int>>>, bfinal: List<G2>, coset: List<List<Int>>, lz: G2, rz: G2, oz: G2, qz: G2, zz: G2, zwz: G2, z: G2, wz: G2, gamd: G2, m: Int, queries: List<Int>, lyrs: Int, finv2: List<Int>) : Bool =
  match bopen { [] => match queries { [] => match topen { [] => true; _ => false }; _ => false };
    [boq, ...brest] => match topen { [] => false; [toq, ...trest] => match queries { [] => false; [p, ...qrest] =>
      if vb3_q1(boq, toq, root1, root2, root3, broots, betas, doms, bfinal, coset, lz, rz, oz, qz, zz, zwz, z, wz, gamd, m, p, lyrs, finv2)
      then vb3_qs(brest, trest, root1, root2, root3, broots, betas, doms, bfinal, coset, lz, rz, oz, qz, zz, zwz, z, wz, gamd, m, qrest, lyrs, finv2) else false } } }
fn verify_b3(gates: List<Gate>, proof: ProofB3) : Bool =
  match proof { ProofB3(root1, root2, root3, lz, rz, oz, qz, zz, zwz, broots, bfinal, nonce, bopen, topen) =>
    let n : Int = ng(gates) in let m : Int = fri_dsize(n) in let coset : List<List<Int>> = fri_coset(n) in let lyrs : Int = fri_layers(n) in let omega : List<Int> = root_pow2(ilog2(n)) in
    let stmt : List<Int> = stmt_seed_of(gates) in let pc : List<List<List<Int>>> = public_cols(gates, n) in let pm : List<List<List<Int>>> = perm_cols(gates, n) in
    let ts1 : List<Int> = hashg(stmt, root1) in let beta : G2 = beta_p_of(ts1) in let gamp : G2 = gam_p_of(ts1) in
    let ts2 : List<Int> = hashg(ts1, root2) in let alpha : G2 = alpha_of(ts2) in
    let ts3 : List<Int> = hashg(ts2, root3) in let z : G2 = ood_of(ts3) in let wz : G2 = gmul2(z, emb(omega)) in
    let ts4 : List<Int> = absorb6(ts3, lz, rz, oz, qz, zz, zwz) in let gamd : G2 = gamma_of(ts4) in
    let betas : List<G2> = rederive_betas(broots, ts4) in let base_seed : List<Int> = absorb_final(seed_from_roots(broots, ts4), bfinal) in
    let ground : List<Int> = hashg(base_seed, glit(nonce)) in let doms : List<List<List<Int>>> = build_doms(coset, lyrs) in
    let queries : List<Int> = sample_queries_g(ground, fri_queries(n), fri_dsize(n)) in
    let id_ok : Bool = geq2(qz, qcombined_z(pc, pm, lz, rz, oz, zz, zwz, beta, gamp, alpha, z, n)) in
    let struct_ok : Bool = (llen(broots) == lyrs) && (len(bfinal) == fri_final(0)) && (openings_len(bopen) == fri_queries(n)) && (tblen(topen) == fri_queries(n)) && pow_ok(ground) && is_const2(bfinal) in
    id_ok && struct_ok && vb3_qs(bopen, topen, root1, root2, root3, broots, betas, doms, bfinal, coset, lz, rz, oz, qz, zz, zwz, z, wz, gamd, m, queries, lyrs, finv([2])) }
# prove_b3 from RAW column values (not a single witness w) — lets us build a
# wiring-INCONSISTENT-but-per-row-valid trace to demonstrate the B3 gap is closed.
fn q_cw_cols(pc: List<List<List<Int>>>, ll: List<List<Int>>, rr: List<List<Int>>, oo: List<List<Int>>, coset: List<List<Int>>, n: Int) : List<List<Int>> =
  quotient_cw(wnth3(pc, 0), wnth3(pc, 1), wnth3(pc, 2), wnth3(pc, 3), wnth3(pc, 4), ll, rr, oo, wnth3(pc, 5), coset, n)
fn low_degree_quotient_cols(gates: List<Gate>, lvals: List<List<Int>>, rvals: List<List<Int>>, ovals: List<List<Int>>) : Bool =
  let n : Int = ng(gates) in let coset : List<List<Int>> = fri_coset(n) in let pc : List<List<List<Int>>> = public_cols(gates, n) in
  is_constb(fold_all_b(q_cw_cols(pc, interp_n(lvals, n), interp_n(rvals, n), interp_n(ovals, n), coset, n), coset, finv([2]), 0))
fn prove_b3_cols(gates: List<Gate>, lvals: List<List<Int>>, rvals: List<List<Int>>, ovals: List<List<Int>>) : ProofB3 =
  let n : Int = ng(gates) in let m : Int = fri_dsize(n) in let coset : List<List<Int>> = fri_coset(n) in let rot : Int = m / n in let omega : List<Int> = root_pow2(ilog2(n)) in
  let stmt : List<Int> = stmt_seed_of(gates) in let pc : List<List<List<Int>>> = public_cols(gates, n) in let pm : List<List<List<Int>>> = perm_cols(gates, n) in
  let cells : List<Pair<Int, Int>> = all_cells(gates, 0, n) in
  let ll : List<List<Int>> = interp_n(lvals, n) in let rr : List<List<Int>> = interp_n(rvals, n) in let oo : List<List<Int>> = interp_n(ovals, n) in
  let lcw : List<List<Int>> = eval_on_dom(ll, coset) in let rcw : List<List<Int>> = eval_on_dom(rr, coset) in let ocw : List<List<Int>> = eval_on_dom(oo, coset) in
  let qgatecw : List<List<Int>> = q_cw_cols(pc, ll, rr, oo, coset, n) in
  let lev1 : List<List<List<Int>>> = build_levels_g(pad_pow2_g(trace_leaf_lro(lcw, rcw, ocw, 0, m)), []) in let root1 : List<Int> = root_of_levels(lev1) in
  let ts1 : List<Int> = hashg(stmt, root1) in let beta : G2 = beta_p_of(ts1) in let gamp : G2 = gam_p_of(ts1) in
  let zvals : List<G2> = z_build(lvals, rvals, ovals, cells, beta, gamp, G2([1], []), 0, n) in
  let zr : List<List<Int>> = interp_n(reals(zvals), n) in let zi : List<List<Int>> = interp_n(imags(zvals), n) in
  let zcw : List<G2> = eval_g2_on_dom(zr, zi, coset) in
  let lev2 : List<List<List<Int>>> = merkle_levels_g(zcw) in let root2 : List<Int> = root_of_levels(lev2) in
  let ts2 : List<Int> = hashg(ts1, root2) in let alpha : G2 = alpha_of(ts2) in
  let qcw : List<G2> = build_q_b3(pc, pm, qgatecw, lcw, rcw, ocw, zcw, coset, alpha, beta, gamp, n, rot, m, 0) in
  let lev3 : List<List<List<Int>>> = merkle_levels_g(qcw) in let root3 : List<Int> = root_of_levels(lev3) in
  let ts3 : List<Int> = hashg(ts2, root3) in let z : G2 = ood_of(ts3) in let wz : G2 = gmul2(z, emb(omega)) in
  let lz : G2 = poly_eval_g(ll, z) in let rz : G2 = poly_eval_g(rr, z) in let oz : G2 = poly_eval_g(oo, z) in
  let zz : G2 = poly_eval_g2(zr, zi, z) in let zwz : G2 = poly_eval_g2(zr, zi, wz) in
  let qz : G2 = qcombined_z(pc, pm, lz, rz, oz, zz, zwz, beta, gamp, alpha, z, n) in
  let ts4 : List<Int> = absorb6(ts3, lz, rz, oz, qz, zz, zwz) in let gamd : G2 = gamma_of(ts4) in
  let bcw : List<G2> = build_b_b3(lcw, rcw, ocw, qcw, zcw, coset, lz, rz, oz, qz, zz, zwz, z, wz, gamd, 0, m) in
  match commit_g(bcw, coset, [], ts4, finv([2])) { (blayers, bfinal) =>
    let base_seed : List<Int> = absorb_final(transcript_seed_g(blayers, ts4), bfinal) in let nz : Int = grind(base_seed) in let ground : List<Int> = hashg(base_seed, glit(nz)) in
    let queries : List<Int> = sample_queries_g(ground, fri_queries(n), fri_dsize(n)) in
    ProofB3(root1, root2, root3, lz, rz, oz, qz, zz, zwz, roots_of(blayers), bfinal, nz, extract_all(blayers, queries), extract_tb(lcw, rcw, ocw, qcw, zcw, lev1, lev2, lev3, queries, m)) }

# --- bridge: parse, inline calls, lower the arithmetic subset to gates -------
fn fn_body_of(fns: List<FnDecl>, name: String) : Expr = match fns { [] => error("glass prove: internal — body of resolved function '" ++ name ++ "' not found"); [FnDecl(fnm, tps, ty, body), ...rest] => if fnm == name then body else fn_body_of(rest, name) }
fn unwind_app(e: Expr, acc: List<Expr>) : (Expr, List<Expr>) = match e { EApp(f, a) => unwind_app(f, [a] ++ acc); _ => (e, acc) }
fn fn_exists(fns: List<FnDecl>, name: String) : Bool = match fns { [] => false; [FnDecl(fnm, tps, ty, body), ...rest] => if fnm == name then true else fn_exists(rest, name) }
fn fenv_get(fenv: List<Pair<String, String>>, name: String) : String = match fenv { [] => ""; [Pair(k, v), ...r] => if k == name then v else fenv_get(r, name) }
fn resolve_fn(name: String, fns: List<FnDecl>, fenv: List<Pair<String, String>>) : String =
  let bound : String = fenv_get(fenv, name) in if bound == "" then (if fn_exists(fns, name) then name else "") else bound
fn is_fn_arg(a: Expr, fns: List<FnDecl>, fenv: List<Pair<String, String>>) : Bool = match a { EVar(n) => resolve_fn(n, fns, fenv) != ""; _ => false }
fn arg_fn_name(a: Expr, fns: List<FnDecl>, fenv: List<Pair<String, String>>) : String = match a { EVar(n) => resolve_fn(n, fns, fenv); _ => "" }
fn unroll_args(es: List<Expr>, fns: List<FnDecl>, fenv: List<Pair<String, String>>, fuel: Int) : List<Expr> =
  match es { [] => []; [e, ...r] => [unroll(e, fns, fenv, fuel)] ++ unroll_args(r, fns, fenv, fuel) }
fn unroll_arms(arms: List<Pair<Pattern, Expr>>, fns: List<FnDecl>, fenv: List<Pair<String, String>>, fuel: Int) : List<Pair<Pattern, Expr>> =
  match arms { [] => []; [Pair(p, b), ...r] => [Pair(p, unroll(b, fns, fenv, fuel))] ++ unroll_arms(r, fns, fenv, fuel) }
fn inline_fn(body: Expr, args: List<Expr>, fns: List<FnDecl>, fenv: List<Pair<String, String>>, fuel: Int) : Expr =
  match body {
    ELam(p, inner) => match args {
      [] => unroll(inner, fns, fenv, fuel - 1);
      [a, ...rest] => if is_fn_arg(a, fns, fenv)
        then inline_fn(inner, rest, fns, [Pair(p, arg_fn_name(a, fns, fenv))] ++ fenv, fuel)
        else ELet(p, unroll(a, fns, fenv, fuel), inline_fn(inner, rest, fns, fenv, fuel)) };
    _ => unroll(body, fns, fenv, fuel - 1) }
fn unroll(e: Expr, fns: List<FnDecl>, fenv: List<Pair<String, String>>, fuel: Int) : Expr =
  match e {
    # fuel <= 0 => EInt(0) is the TERMINATOR of bounded symbolic unrolling, NOT an error:
    # the unroller can't stop a recursion at its (runtime) base case, so it unrolls to the
    # fuel bound and caps with 0. For runtime depth <= fuel the cap is never selected (the
    # `if`s short-circuit on the witness first) and the result is exact; deeper recursion is
    # silently truncated — a known circuit-model limitation (see soundness.md), not fixable
    # here without breaking every recursive program. The genuine-error fallbacks below DO
    # refuse loudly (unresolved / higher-order callee — programs the bridge cannot lower).
    EApp(f, a) => if fuel <= 0 then EInt(0) else match unwind_app(EApp(f, a), []) { (hd, args) => match hd {
      EVar(fname) => let tgt : String = resolve_fn(fname, fns, fenv) in if tgt == "" then error("glass prove: unresolved call to '" ++ fname ++ "' — the prove bridge cannot lower this construct to a gate circuit (a silent proven-0 is refused)") else inline_fn(fn_body_of(fns, tgt), args, fns, fenv, fuel);
      _ => error("glass prove: unsupported call form (computed or higher-order callee) — cannot lower to a gate circuit (a silent proven-0 is refused)") } };
    EAdd(x, y) => EAdd(unroll(x, fns, fenv, fuel), unroll(y, fns, fenv, fuel));
    ESub(x, y) => ESub(unroll(x, fns, fenv, fuel), unroll(y, fns, fenv, fuel));
    EMul(x, y) => EMul(unroll(x, fns, fenv, fuel), unroll(y, fns, fenv, fuel));
    EEq(x, y) => EEq(unroll(x, fns, fenv, fuel), unroll(y, fns, fenv, fuel));
    EIf(c, t, f) => EIf(unroll(c, fns, fenv, fuel), unroll(t, fns, fenv, fuel), unroll(f, fns, fenv, fuel));
    ELet(nm, v, body) => ELet(nm, unroll(v, fns, fenv, fuel), unroll(body, fns, fenv, fuel));
    EMatch(scrut, arms) => EMatch(unroll(scrut, fns, fenv, fuel), unroll_arms(arms, fns, fenv, fuel));
    ECtor(name, args) => ECtor(name, unroll_args(args, fns, fenv, fuel));
    ETuple(elems) => ETuple(unroll_args(elems, fns, fenv, fuel));
    _ => e }

fn env_get2(env: List<Pair<String, Int>>, name: String) : Int = match env { [] => 0 - 1; [Pair(k, v), ...r] => if k == name then v else env_get2(r, name) }

# === R1b foundation: multi-wire ADT support over Goldilocks (staged) ==========
# A value is a wire LIST: scalar Int -> [w]; ADT Ctor(a,b) -> [tag, wa, wb]; tuple
# (a,b) -> [wa, wb]. These field-agnostic helpers (tags, type-directed widths) +
# bignum/wire-index list helpers are the foundation; heval (spec) + cgen (circuit)
# are the next stages. Ported from prove_source_adt_zk.glass, adapted to bignum.
fn nthI(xs: List<Int>, i: Int) : Int = match xs { [] => 0; [h, ...t] => if i == 0 then h else nthI(t, i - 1) }
fn ilenI(xs: List<Int>) : Int = match xs { [] => 0; [x, ...r] => 1 + ilenI(r) }
fn vh(v: List<List<Int>>) : List<Int> = wnth(v, 0)
fn slw(sv: List<List<Int>>, off: Int, w: Int) : List<List<Int>> = if w <= 0 then [] else [wnth(sv, off)] ++ slw(sv, off + 1, w - 1)
fn padw(v: List<List<Int>>, t: Int) : List<List<Int>> = if llen(v) >= t then v else padw(v ++ [glit(0)], t)
fn ctix(ctors: List<CtorDecl>, name: String, i: Int) : Int = match ctors { [] => 0 - 1; [CtorDecl(cn, ats), ...r] => if cn == name then i else ctix(r, name, i + 1) }
fn ctag(types: List<TypeDecl>, name: String) : Int = match types { [] => 0; [TypeDecl(tn, tps, ctors), ...r] => let idx : Int = ctix(ctors, name, 0) in if idx >= 0 then idx else ctag(r, name) }
fn find_type(types: List<TypeDecl>, name: String) : List<CtorDecl> = match types { [] => []; [TypeDecl(tn, tps, ctors), ...r] => if tn == name then ctors else find_type(r, name) }
fn has_ctor(ctors: List<CtorDecl>, name: String) : Bool = match ctors { [] => false; [CtorDecl(cn, ats), ...r] => if cn == name then true else has_ctor(r, name) }
fn get_args(ctors: List<CtorDecl>, name: String) : List<Type> = match ctors { [] => []; [CtorDecl(cn, ats), ...r] => if cn == name then ats else get_args(r, name) }
fn ctor_argtypes(types: List<TypeDecl>, name: String) : List<Type> = match types { [] => []; [TypeDecl(tn, tps, ctors), ...r] => if has_ctor(ctors, name) then get_args(ctors, name) else ctor_argtypes(r, name) }
fn scalar_types_e(xs: List<Expr>) : List<Type> = match xs { [] => []; [x, ...r] => [TyInt] ++ scalar_types_e(r) }
fn twidth(ty: Type, types: List<TypeDecl>, fuel: Int) : Int = if fuel <= 0 then 1 else match ty { TyAdt(name, args) => match find_type(types, name) { [] => 1; cs => 1 + max_ctor_width(cs, types, fuel - 1) }; TyTuple(tys) => ctor_wsum(tys, types, fuel - 1); _ => 1 }
fn ctor_wsum(args: List<Type>, types: List<TypeDecl>, fuel: Int) : Int = match args { [] => 0; [a, ...r] => twidth(a, types, fuel) + ctor_wsum(r, types, fuel) }
fn max_ctor_width(ctors: List<CtorDecl>, types: List<TypeDecl>, fuel: Int) : Int = match ctors { [] => 0; [CtorDecl(cn, ats), ...r] => let w : Int = ctor_wsum(ats, types, fuel) in let rw : Int = max_ctor_width(r, types, fuel) in if w >= rw then w else rw }

# --- R1b stage 1: heval, the reference evaluator (SPEC) for ADTs over Goldilocks --
# A value is multi-wire: scalar [v]; ADT Ctor(a,b) -> [tag, fa, fb]; tuple [a, b].
# (int -> bignum vs the Baby Bear original: values List<List<Int>>, vh first comp,
# tags via glit, is-zero via bn_is_zero.)
fn scalar_types_p(xs: List<Pattern>) : List<Type> = match xs { [] => []; [x, ...r] => [TyInt] ++ scalar_types_p(r) }
fn heg(env: List<Pair<String, List<List<Int>>>>, name: String) : List<List<Int>> = match env { [] => [glit(0)]; [Pair(k, v), ...r] => if k == name then v else heg(r, name) }
fn heval(e: Expr, env: List<Pair<String, List<List<Int>>>>, fns: List<FnDecl>, types: List<TypeDecl>) : (List<List<Int>>, List<List<Int>>) =
  match e {
    EInt(n) => ([glit(n)], []);
    EBool(tf) => ([if tf then glit(1) else glit(0)], []);
    EVar(x) => (heg(env, x), []);
    EAdd(a, b) => match heval(a, env, fns, types) { (va, ha) => match heval(b, env, fns, types) { (vb, hb) => ([fadd(vh(va), vh(vb))], ha ++ hb) } };
    ESub(a, b) => match heval(a, env, fns, types) { (va, ha) => match heval(b, env, fns, types) { (vb, hb) => ([fsub(vh(va), vh(vb))], ha ++ hb) } };
    EMul(a, b) => match heval(a, env, fns, types) { (va, ha) => match heval(b, env, fns, types) { (vb, hb) => ([fmul(vh(va), vh(vb))], ha ++ hb) } };
    EEq(a, b) => match heval(a, env, fns, types) { (va, ha) => match heval(b, env, fns, types) { (vb, hb) =>
      let d : List<Int> = fsub(vh(va), vh(vb)) in ([if bn_is_zero(d) then glit(1) else glit(0)], ha ++ hb ++ [if bn_is_zero(d) then glit(0) else finv(d)]) } };
    EIf(c, t, f) => match heval(c, env, fns, types) { (vc, hc) => match heval(t, env, fns, types) { (vt, ht) => match heval(f, env, fns, types) { (vf, hf) => (if bn_eq(vh(vc), glit(1)) then vt else vf, hc ++ ht ++ hf) } } };
    ELet(nm, v, body) => match heval(v, env, fns, types) { (vv, hv) => match heval(body, [Pair(nm, vv)] ++ env, fns, types) { (vb, hb) => (vb, hv ++ hb) } };
    ECtor(name, args) => match heval_fields(args, ctor_argtypes(types, name), env, fns, types) { (vals, hs) => ([glit(ctag(types, name))] ++ vals, hs) };
    ETuple(elems) => heval_fields(elems, scalar_types_e(elems), env, fns, types);
    EApp(f, a) => match unwind_app(EApp(f, a), []) { (hd, args) => match hd { EVar(fname) => heval_call(fn_body_of(fns, fname), args, [], env, fns, types); _ => ([glit(0)], []) } };
    EMatch(scrut, arms) => match heval(scrut, env, fns, types) { (sv, hs) => match heval_match(sv, arms, env, fns, types) { (rv, ha) => (rv, hs ++ ha) } };
    _ => ([glit(0)], []) }
fn heval_fields(args: List<Expr>, tys: List<Type>, env: List<Pair<String, List<List<Int>>>>, fns: List<FnDecl>, types: List<TypeDecl>) : (List<List<Int>>, List<List<Int>>) =
  match args { [] => ([], []); [a, ...arest] => match tys { [] => ([], []); [t, ...trest] =>
    match heval(a, env, fns, types) { (va, ha) => match heval_fields(arest, trest, env, fns, types) { (vr, hr) =>
      (padw(va, twidth(t, types, 12)) ++ vr, ha ++ hr) } } } }
fn heval_call(body: Expr, args: List<Expr>, ccenv: List<Pair<String, List<List<Int>>>>, fcenv: List<Pair<String, List<List<Int>>>>, fns: List<FnDecl>, types: List<TypeDecl>) : (List<List<Int>>, List<List<Int>>) =
  match body {
    ELam(p, inner) => match args { [] => heval(body, ccenv, fns, types); [a, ...rest] => match heval(a, fcenv, fns, types) { (va, ha) => match heval_call(inner, rest, [Pair(p, va)] ++ ccenv, fcenv, fns, types) { (vr, hr) => (vr, ha ++ hr) } } };
    _ => heval(body, ccenv, fns, types) }
fn pmatch(p: Pattern, sv: List<List<Int>>, types: List<TypeDecl>) : Bool =
  match p { PWild => true; PVar(x) => true; PInt(n) => bn_eq(vh(sv), glit(n)); PBool(bb) => bn_eq(vh(sv), if bb then glit(1) else glit(0)); PCtor(nm, ps) => if bn_eq(vh(sv), glit(ctag(types, nm))) then pmatch_fields(ps, ctor_argtypes(types, nm), sv, 1, types) else false; PTuple(ps) => pmatch_fields(ps, scalar_types_p(ps), sv, 0, types); PStr(s) => false; PRecord(nm, fs) => false }
fn pmatch_fields(ps: List<Pattern>, tys: List<Type>, sv: List<List<Int>>, off: Int, types: List<TypeDecl>) : Bool =
  match ps { [] => true; [p, ...prest] => match tys { [] => true; [t, ...trest] =>
    let wt : Int = twidth(t, types, 12) in if pmatch(p, slw(sv, off, wt), types) then pmatch_fields(prest, trest, sv, off + wt, types) else false } }
fn pbind(p: Pattern, sv: List<List<Int>>, types: List<TypeDecl>, env: List<Pair<String, List<List<Int>>>>) : List<Pair<String, List<List<Int>>>> =
  match p { PVar(x) => [Pair(x, sv)] ++ env; PCtor(nm, ps) => pbind_fields(ps, ctor_argtypes(types, nm), sv, 1, types, env); PWild => env; PInt(n) => env; PBool(bb) => env; PTuple(ps) => pbind_fields(ps, scalar_types_p(ps), sv, 0, types, env); PStr(s) => env; PRecord(nm, fs) => env }
fn pbind_fields(ps: List<Pattern>, tys: List<Type>, sv: List<List<Int>>, off: Int, types: List<TypeDecl>, env: List<Pair<String, List<List<Int>>>>) : List<Pair<String, List<List<Int>>>> =
  match ps { [] => env; [p, ...prest] => match tys { [] => env; [t, ...trest] =>
    let wt : Int = twidth(t, types, 12) in pbind_fields(prest, trest, sv, off + wt, types, pbind(p, slw(sv, off, wt), types, env)) } }
fn psel_hint(p: Pattern, sv: List<List<Int>>, types: List<TypeDecl>) : List<List<Int>> =
  match p { PInt(n) => let d : List<Int> = fsub(vh(sv), glit(n)) in [if bn_is_zero(d) then glit(0) else finv(d)]; PBool(bb) => let d : List<Int> = fsub(vh(sv), if bb then glit(1) else glit(0)) in [if bn_is_zero(d) then glit(0) else finv(d)]; PCtor(nm, ps) => let d : List<Int> = fsub(vh(sv), glit(ctag(types, nm))) in [if bn_is_zero(d) then glit(0) else finv(d)] ++ psel_hint_fields(ps, ctor_argtypes(types, nm), sv, 1, types); PWild => []; PVar(x) => []; PTuple(ps) => psel_hint_fields(ps, scalar_types_p(ps), sv, 0, types); PStr(s) => []; PRecord(nm, fs) => [] }
fn psel_hint_fields(ps: List<Pattern>, tys: List<Type>, sv: List<List<Int>>, off: Int, types: List<TypeDecl>) : List<List<Int>> =
  match ps { [] => []; [p, ...prest] => match tys { [] => []; [t, ...trest] =>
    let wt : Int = twidth(t, types, 12) in psel_hint(p, slw(sv, off, wt), types) ++ psel_hint_fields(prest, trest, sv, off + wt, types) } }
fn heval_match(sv: List<List<Int>>, arms: List<Pair<Pattern, Expr>>, env: List<Pair<String, List<List<Int>>>>, fns: List<FnDecl>, types: List<TypeDecl>) : (List<List<Int>>, List<List<Int>>) =
  match arms { [] => ([glit(0)], []);
    [Pair(p, body), ...rest] =>
      let sh : List<List<Int>> = psel_hint(p, sv, types) in
      match heval(body, pbind(p, sv, types, env), fns, types) { (bv, bh) =>
      match heval_match(sv, rest, env, fns, types) { (rv, rh) =>
        (if pmatch(p, sv, types) then bv else rv, sh ++ bh ++ rh) } } }

# --- bounded-unroll depth: ONE source of truth so seval and unroll can never drift ---
fn unroll_fuel(d: Int) : Int = 8

# --- seval: a SHORT-CIRCUITING, fuel-limited reference interpreter over the SAME multi-wire
# value domain as heval/cgen (scalar [v]; ADT [tag, ...fields]; tuple). It evaluates the SOURCE
# with calls intact and is a PURE GUARD: it never builds a gate, never calls prove_b3/verify_b3.
# Unlike heval (which evaluates BOTH if-arms and EVERY match-arm to accumulate hints), seval
# descends ONLY the taken arm + the first matching pattern, and decrements `fuel` once per
# SATURATED call IN LOCKSTEP with inline_fn: spine args at the current fuel (no decrement), the
# saturated body at fuel-1 (seval_call's `[] =>` / `_ =>`), and the cap check `fuel <= 0` AT the
# EApp node (mirroring unroll). So it reaches a call-at-fuel-0 ONLY when the genuinely-taken
# runtime recursion is deeper than the unroll bound -> exactly the case the fuel-bounded circuit
# would SILENTLY TRUNCATE. There it calls `error` (loud refuse) instead of yielding a truncated
# value. Within fuel it returns the same value the circuit proves (accept-set is a SUBSET of the
# circuit-faithful set). HONEST SCOPE: this guards the CLI's honest R-computation path; a
# malicious prover building a truncated circuit directly (or calling gprove_sound with a forged
# R) is OUT of the soundness threat model (faithful-lowering, audit-readiness.md) — the
# do-not-protect-real-value banner stays.
fn seval(e: Expr, env: List<Pair<String, List<List<Int>>>>, fns: List<FnDecl>, types: List<TypeDecl>, fuel: Int) : List<List<Int>> =
  match e {
    EInt(n) => [glit(n)];
    EBool(tf) => [if tf then glit(1) else glit(0)];
    EVar(x) => heg(env, x);
    EAdd(a, b) => [fadd(vh(seval(a, env, fns, types, fuel)), vh(seval(b, env, fns, types, fuel)))];
    ESub(a, b) => [fsub(vh(seval(a, env, fns, types, fuel)), vh(seval(b, env, fns, types, fuel)))];
    EMul(a, b) => [fmul(vh(seval(a, env, fns, types, fuel)), vh(seval(b, env, fns, types, fuel)))];
    EEq(a, b) => let d : List<Int> = fsub(vh(seval(a, env, fns, types, fuel)), vh(seval(b, env, fns, types, fuel))) in [if bn_is_zero(d) then glit(1) else glit(0)];
    EIf(c, t, f) => if bn_eq(vh(seval(c, env, fns, types, fuel)), glit(1)) then seval(t, env, fns, types, fuel) else seval(f, env, fns, types, fuel);
    ELet(nm, v, body) => seval(body, [Pair(nm, seval(v, env, fns, types, fuel))] ++ env, fns, types, fuel);
    ECtor(name, args) => [glit(ctag(types, name))] ++ seval_fields(args, ctor_argtypes(types, name), env, fns, types, fuel);
    ETuple(elems) => seval_fields(elems, scalar_types_e(elems), env, fns, types, fuel);
    EApp(f, a) => match unwind_app(EApp(f, a), []) { (hd, args) => match hd {
      EVar(fname) => if fuel <= 0 then error("glass prove: recursion depth exceeds the unroll bound (" ++ int_to_string(unroll_fuel(0)) ++ "); refusing to prove a depth-truncated result — it would otherwise be a silently wrong value with a valid-looking proof (the program needs statically-bounded, shallower recursion)") else (let tgt : String = resolve_fn(fname, fns, []) in if tgt == "" then error("glass prove: unresolved call to '" ++ fname ++ "' in the reference evaluator") else seval_call(fn_body_of(fns, tgt), args, [], env, fns, types, fuel));
      _ => error("glass prove: unsupported call form (computed or higher-order callee) in the reference evaluator") } };
    EMatch(scrut, arms) => seval_match(seval(scrut, env, fns, types, fuel), arms, env, fns, types, fuel);
    _ => [glit(0)] }
fn seval_fields(args: List<Expr>, tys: List<Type>, env: List<Pair<String, List<List<Int>>>>, fns: List<FnDecl>, types: List<TypeDecl>, fuel: Int) : List<List<Int>> =
  match args { [] => []; [a, ...arest] => match tys { [] => []; [t, ...trest] =>
    padw(seval(a, env, fns, types, fuel), twidth(t, types, 12)) ++ seval_fields(arest, trest, env, fns, types, fuel) } }
fn seval_call(body: Expr, args: List<Expr>, ccenv: List<Pair<String, List<List<Int>>>>, fcenv: List<Pair<String, List<List<Int>>>>, fns: List<FnDecl>, types: List<TypeDecl>, fuel: Int) : List<List<Int>> =
  match body {
    ELam(p, inner) => match args { [] => seval(body, ccenv, fns, types, fuel - 1); [a, ...rest] => let va : List<List<Int>> = seval(a, fcenv, fns, types, fuel) in seval_call(inner, rest, [Pair(p, va)] ++ ccenv, fcenv, fns, types, fuel) };
    _ => seval(body, ccenv, fns, types, fuel - 1) }
fn seval_match(sv: List<List<Int>>, arms: List<Pair<Pattern, Expr>>, env: List<Pair<String, List<List<Int>>>>, fns: List<FnDecl>, types: List<TypeDecl>, fuel: Int) : List<List<Int>> =
  match arms { [] => [glit(0)]; [Pair(p, body), ...rest] => if pmatch(p, sv, types) then seval(body, pbind(p, sv, types, env), fns, types, fuel) else seval_match(sv, rest, env, fns, types, fuel) }

fn gref_h(src: String) : List<List<Int>> = match parse_prog(src) { Program(types, fns, main) => match heval(unroll(main, fns, [], unroll_fuel(0)), [], fns, types) { (v, h) => v } }

# --- R1b stage 2: cgen, the multi-wire circuit generator for ADTs --------------
# Value = wire-index LIST (List<Int>): scalar [w]; ADT [tag, ...fields]; tuple [...].
# Inline is-zero hints via mkh (no hint region), bignum constants via glit. Adapted
# from prove_source_adt_zk's cgen; mk_eq_g is the Goldilocks is-zero gadget.
fn slwi(sv: List<Int>, off: Int, w: Int) : List<Int> = if w <= 0 then [] else [nthI(sv, off)] ++ slwi(sv, off + 1, w - 1)
fn vhi(v: List<Int>) : Int = nthI(v, 0)
fn cenv_get(cenv: List<Pair<String, List<Int>>>, name: String) : List<Int> = match cenv { [] => [0 - 1]; [Pair(k, v), ...r] => if k == name then v else cenv_get(r, name) }
fn padv_g(v: List<Int>, target: Int, b: Build) : (List<Int>, Build) = if ilenI(v) >= target then (v, b) else match mkc(glit(0), b) { (z, b1) => padv_g(v ++ [z], target, b1) }
fn mk_eq_g(wx: Int, wy: Int, b: Build) : (Int, Build) =
  match mks(wx, wy, b) { (wd, b1) => let dv : List<Int> = bwire(b1, wd) in let iv : List<Int> = if bn_is_zero(dv) then glit(0) else finv(dv) in
  match mkh(iv, b1) { (winv, b2) => match mkm(wd, winv, b2) { (wdi, b3) => match mkc(glit(1), b3) { (wone, b4) =>
  match mks(wone, wdi, b4) { (wz, b5) => match mkm(wz, wd, b5) { (wzd, b6) => (wz, mke(wzd, b6)) } } } } } }
fn muxw(wc: Int, vt: List<Int>, vf: List<Int>, b: Build) : (List<Int>, Build) =
  match vt { [] => ([], b); [t, ...tr] => match vf { [] => ([], b); [f, ...fr] =>
    match mks(t, f, b) { (wd, b1) => match mkm(wc, wd, b1) { (wcd, b2) => match mka(f, wcd, b2) { (wo, b3) =>
    match muxw(wc, tr, fr, b3) { (rest, b4) => ([wo] ++ rest, b4) } } } } } }
fn cgen(e: Expr, cenv: List<Pair<String, List<Int>>>, fns: List<FnDecl>, types: List<TypeDecl>, b: Build) : (List<Int>, Build) =
  match e {
    EInt(n) => match mkc(glit(n), b) { (w, b1) => ([w], b1) };
    EBool(tf) => match mkc(if tf then glit(1) else glit(0), b) { (w, b1) => ([w], b1) };
    EVar(x) => (cenv_get(cenv, x), b);
    EAdd(x, y) => match cgen(x, cenv, fns, types, b) { (vx, b1) => match cgen(y, cenv, fns, types, b1) { (vy, b2) => match mka(vhi(vx), vhi(vy), b2) { (wo, b3) => ([wo], b3) } } };
    ESub(x, y) => match cgen(x, cenv, fns, types, b) { (vx, b1) => match cgen(y, cenv, fns, types, b1) { (vy, b2) => match mks(vhi(vx), vhi(vy), b2) { (wo, b3) => ([wo], b3) } } };
    EMul(x, y) => match cgen(x, cenv, fns, types, b) { (vx, b1) => match cgen(y, cenv, fns, types, b1) { (vy, b2) => match mkm(vhi(vx), vhi(vy), b2) { (wo, b3) => ([wo], b3) } } };
    EEq(x, y) => match cgen(x, cenv, fns, types, b) { (vx, b1) => match cgen(y, cenv, fns, types, b1) { (vy, b2) => match mk_eq_g(vhi(vx), vhi(vy), b2) { (wo, b3) => ([wo], b3) } } };
    EIf(c, t, f) => match cgen(c, cenv, fns, types, b) { (vc, b1) => match cgen(t, cenv, fns, types, b1) { (vt, b2) => match cgen(f, cenv, fns, types, b2) { (vf, b3) => muxw(vhi(vc), vt, vf, b3) } } };
    ELet(nm, v, body) => match cgen(v, cenv, fns, types, b) { (vv, b1) => cgen(body, [Pair(nm, vv)] ++ cenv, fns, types, b1) };
    ECtor(name, args) => match mkc(glit(ctag(types, name)), b) { (wtag, b1) => match cgen_fields(args, ctor_argtypes(types, name), cenv, fns, types, b1) { (fws, b2) => ([wtag] ++ fws, b2) } };
    ETuple(elems) => cgen_fields(elems, scalar_types_e(elems), cenv, fns, types, b);
    EApp(f, a) => match unwind_app(EApp(f, a), []) { (hd, args) => match hd { EVar(fname) => cgen_call(fn_body_of(fns, fname), args, [], cenv, fns, types, b); _ => match mkc(glit(0), b) { (w, b1) => ([w], b1) } } };
    EMatch(scrut, arms) => match cgen(scrut, cenv, fns, types, b) { (sv, b1) => match mkc(glit(0), b1) { (zm, b2) => cgen_match(arms, sv, cenv, fns, types, zm, [], b2) } };
    _ => match mkc(glit(0), b) { (w, b1) => ([w], b1) } }
fn cgen_fields(args: List<Expr>, tys: List<Type>, cenv: List<Pair<String, List<Int>>>, fns: List<FnDecl>, types: List<TypeDecl>, b: Build) : (List<Int>, Build) =
  match args { [] => ([], b); [a, ...arest] => match tys { [] => ([], b); [t, ...trest] =>
    match cgen(a, cenv, fns, types, b) { (va, b1) => match padv_g(va, twidth(t, types, 12), b1) { (pva, b2) =>
    match cgen_fields(arest, trest, cenv, fns, types, b2) { (vr, b3) => (pva ++ vr, b3) } } } } }
fn cgen_call(body: Expr, args: List<Expr>, ccenv: List<Pair<String, List<Int>>>, fcenv: List<Pair<String, List<Int>>>, fns: List<FnDecl>, types: List<TypeDecl>, b: Build) : (List<Int>, Build) =
  match body { ELam(p, inner) => match args { [] => cgen(body, ccenv, fns, types, b); [a, ...rest] => match cgen(a, fcenv, fns, types, b) { (va, b1) => cgen_call(inner, rest, [Pair(p, va)] ++ ccenv, fcenv, fns, types, b1) } }; _ => cgen(body, ccenv, fns, types, b) }
fn psel(p: Pattern, sv: List<Int>, types: List<TypeDecl>, b: Build) : (Int, Build) =
  match p { PWild => mkc(glit(1), b); PVar(x) => mkc(glit(1), b);
    PInt(n) => match mkc(glit(n), b) { (wn, b1) => mk_eq_g(vhi(sv), wn, b1) };
    PBool(bb) => match mkc(if bb then glit(1) else glit(0), b) { (wn, b1) => mk_eq_g(vhi(sv), wn, b1) };
    PCtor(nm, ps) => match mkc(glit(ctag(types, nm)), b) { (wn, b1) => match mk_eq_g(vhi(sv), wn, b1) { (s0, b2) => psel_fields(ps, ctor_argtypes(types, nm), sv, 1, types, s0, b2) } };
    PTuple(ps) => match mkc(glit(1), b) { (one, b1) => psel_fields(ps, scalar_types_p(ps), sv, 0, types, one, b1) };
    PStr(s) => mkc(glit(0), b); PRecord(nm, fs) => mkc(glit(0), b) }
fn psel_fields(ps: List<Pattern>, tys: List<Type>, sv: List<Int>, off: Int, types: List<TypeDecl>, acc: Int, b: Build) : (Int, Build) =
  match ps { [] => (acc, b); [p, ...prest] => match tys { [] => (acc, b); [t, ...trest] =>
    let wt : Int = twidth(t, types, 12) in match psel(p, slwi(sv, off, wt), types, b) { (s, b1) => match mkm(acc, s, b1) { (acc2, b2) => psel_fields(prest, trest, sv, off + wt, types, acc2, b2) } } } }
fn cbind(p: Pattern, sv: List<Int>, types: List<TypeDecl>, cenv: List<Pair<String, List<Int>>>) : List<Pair<String, List<Int>>> =
  match p { PVar(x) => [Pair(x, sv)] ++ cenv; PCtor(nm, ps) => cbind_fields(ps, ctor_argtypes(types, nm), sv, 1, types, cenv); PWild => cenv; PInt(n) => cenv; PBool(bb) => cenv; PTuple(ps) => cbind_fields(ps, scalar_types_p(ps), sv, 0, types, cenv); PStr(s) => cenv; PRecord(nm, fs) => cenv }
fn cbind_fields(ps: List<Pattern>, tys: List<Type>, sv: List<Int>, off: Int, types: List<TypeDecl>, cenv: List<Pair<String, List<Int>>>) : List<Pair<String, List<Int>>> =
  match ps { [] => cenv; [p, ...prest] => match tys { [] => cenv; [t, ...trest] =>
    let wt : Int = twidth(t, types, 12) in cbind_fields(prest, trest, sv, off + wt, types, cbind(p, slwi(sv, off, wt), types, cenv)) } }
fn accw(result: List<Int>, eff: Int, body: List<Int>, b: Build) : (List<Int>, Build) =
  match body { [] => ([], b); [bi, ...br] => match mkm(eff, bi, b) { (contrib, b1) =>
    match result { [] => match accw([], eff, br, b1) { (rest, b2) => ([contrib] ++ rest, b2) };
      [ri, ...rr] => match mka(ri, contrib, b1) { (nri, b2) => match accw(rr, eff, br, b2) { (rest, b3) => ([nri] ++ rest, b3) } } } } }
fn cgen_match(arms: List<Pair<Pattern, Expr>>, sv: List<Int>, cenv: List<Pair<String, List<Int>>>, fns: List<FnDecl>, types: List<TypeDecl>, matched: Int, result: List<Int>, b: Build) : (List<Int>, Build) =
  match arms { [] => (result, b);
    [Pair(p, body), ...rest] =>
      match psel(p, sv, types, b) { (sel, b1) => match mkc(glit(1), b1) { (one, b2) => match mks(one, matched, b2) { (notm, b3) =>
      match mkm(sel, notm, b3) { (eff, b4) => match cgen(body, cbind(p, sv, types, cenv), fns, types, b4) { (vb, b5) =>
      match accw(result, eff, vb, b5) { (nres, b6) => match mka(matched, eff, b6) { (nm, b7) => cgen_match(rest, sv, cenv, fns, types, nm, nres, b7) } } } } } } } }
# cgen-as-reference: build the circuit, read the output wires' witness values (must equal heval)
fn wmap(ws: List<Int>, w: List<List<Int>>) : List<List<Int>> = match ws { [] => []; [i, ...r] => [wnth(w, i)] ++ wmap(r, w) }
fn cref(src: String) : List<List<Int>> = match parse_prog(src) { Program(types, fns, main) =>
  match cgen(unroll(main, fns, [], unroll_fuel(0)), [], fns, types, Build(0, [], [])) { (outws, b) => match b { Build(n, gs, w) => wmap(outws, w) } } }

# lower a call-free arithmetic Expr to gates; returns (output wire index, Build)
fn cg(e: Expr, env: List<Pair<String, Int>>, b: Build) : (Int, Build) =
  match e {
    EInt(n) => mkc(glit(n), b);
    EVar(x) => (env_get2(env, x), b);
    EAdd(x, y) => match cg(x, env, b) { (wx, b1) => match cg(y, env, b1) { (wy, b2) => mka(wx, wy, b2) } };
    ESub(x, y) => match cg(x, env, b) { (wx, b1) => match cg(y, env, b1) { (wy, b2) => mks(wx, wy, b2) } };
    EMul(x, y) => match cg(x, env, b) { (wx, b1) => match cg(y, env, b1) { (wy, b2) => mkm(wx, wy, b2) } };
    # a == b  ->  is-zero gadget on d = a - b. inv is a free hint (d^-1, or 0 when d=0);
    # then di = d*inv, z = 1 - di, and the assert z*d == 0 forces z = (d==0). z is 0/1.
    EEq(x, y) => match cg(x, env, b) { (wx, b1) => match cg(y, env, b1) { (wy, b2) =>
      match mks(wx, wy, b2) { (wd, b3) =>
        let dv : List<Int> = bwire(b3, wd) in
        let iv : List<Int> = if bn_is_zero(dv) then glit(0) else finv(dv) in
        match mkh(iv, b3) { (winv, b4) =>
          match mkm(wd, winv, b4) { (wdi, b5) =>
            match mkc(glit(1), b5) { (wone, b6) =>
              match mks(wone, wdi, b6) { (wz, b7) =>
                match mkm(wz, wd, b7) { (wzd, b8) => (wz, mke(wzd, b8)) } } } } } } } };
    # if c then t else f  ->  f + c*(t - f), with c a 0/1 wire (from a comparison)
    EIf(c, t, f) => match cg(c, env, b) { (wc, b1) => match cg(t, env, b1) { (wt, b2) => match cg(f, env, b2) { (wf, b3) =>
      match mks(wt, wf, b3) { (wtf, b4) => match mkm(wc, wtf, b4) { (wctf, b5) => mka(wf, wctf, b5) } } } } };
    ELet(nm, v, body) => match cg(v, env, b) { (wv, b1) => cg(body, [Pair(nm, wv)] ++ env, b1) };
    _ => mkc(glit(0), b) }
# parse, inline calls, lower; wire 0 = the private input `inp`
fn parse_prog(src: String) : Program = match parse_program(src) { Ok(p) => p; Err(m) => error("glass prove: parse error — " ++ m ++ " (refusing to prove the empty/0 program)") }
fn build_src(src: String, inpv: List<Int>) : (Int, Build) =
  match parse_prog(src) { Program(types, fns, main) =>
    cg(unroll(main, fns, [], unroll_fuel(0)), [Pair("inp", 0)], Build(1, [], [inpv])) }
fn src_result(src: String, inpv: List<Int>) : List<Int> =
  match build_src(src, inpv) { (out, b) => match b { Build(n, gs, w) => wnth(w, out) } }

# --- multi-input: each named private input on its own low wire (0..k-1) -------
# This is what `glass prove --goldilocks <file> a=.. b=..` lowers to: the inputs
# are PRIVATE (kept in the witness), the output wire is the function's result, and
# (for proving) we assert output == the claimed result so a wrong claim is rejected.
fn in_cenv_g(inputs: List<Pair<String, Int>>, i: Int) : List<Pair<String, Int>> =
  match inputs { [] => []; [Pair(nm, v), ...r] => [Pair(nm, i)] ++ in_cenv_g(r, i + 1) }
fn in_vals_g(inputs: List<Pair<String, Int>>) : List<List<Int>> =
  match inputs { [] => []; [Pair(nm, v), ...r] => [glit4(v)] ++ in_vals_g(r) }
fn iplen(xs: List<Pair<String, Int>>) : Int = match xs { [] => 0; [x, ...r] => 1 + iplen(r) }
fn build_multi(src: String, inputs: List<Pair<String, Int>>) : (Int, Build) =
  match parse_prog(src) { Program(types, fns, main) =>
    cg(unroll(main, fns, [], unroll_fuel(0)), in_cenv_g(inputs, 0), Build(iplen(inputs), [], in_vals_g(inputs))) }
fn gref(src: String, inputs: List<Pair<String, Int>>) : List<Int> =
  match build_multi(src, inputs) { (out, b) => match b { Build(n, gs, w) => wnth(w, out) } }
# bind the claimed result: assert (output - claimedR) == 0 via the is-zero assert gate
fn build_claim(src: String, inputs: List<Pair<String, Int>>, claimedR: List<Int>) : Build =
  match build_multi(src, inputs) { (out, b) =>
    match mkc(claimedR, b) { (wR, b1) => match mks(out, wR, b1) { (wd, b2) => mke(wd, b2) } } }
fn gprove(src: String, inputs: List<Pair<String, Int>>, claimedR: List<Int>, seed: Int) : Bool =
  match build_claim(src, inputs, claimedR) { Build(n, gs, w) => prove_stark(gs, w, seed) }
# --- R1b stage 3: multi-wire prove path (cgen) — proves programs that USE ADTs ---
# scalar inputs sit on low wires [0..n); each binds to a single-wire value [i].
fn in_cenv_m(inputs: List<Pair<String, Int>>, i: Int) : List<Pair<String, List<Int>>> =
  match inputs { [] => []; [Pair(nm, v), ...r] => [Pair(nm, [i])] ++ in_cenv_m(r, i + 1) }
fn build_multi_m(src: String, inputs: List<Pair<String, Int>>) : (List<Int>, Build) =
  match parse_prog(src) { Program(types, fns, main) =>
    cgen(unroll(main, fns, [], unroll_fuel(0)), in_cenv_m(inputs, 0), fns, types, Build(iplen(inputs), [], in_vals_g(inputs))) }
fn gref_m(src: String, inputs: List<Pair<String, Int>>) : List<List<Int>> =
  match build_multi_m(src, inputs) { (outws, b) => match b { Build(n, gs, w) => wmap(outws, w) } }
# seval's initial env from CLI inputs, matching in_vals_g's VALUE (glit4 full-width, NOT glit)
# so seval agrees with the circuit on large inputs (else a spurious refusal/REJECT near 2^48).
fn in_cenv_seval(inputs: List<Pair<String, Int>>) : List<Pair<String, List<List<Int>>>> =
  match inputs { [] => []; [Pair(nm, v), ...r] => [Pair(nm, [glit4(v)])] ++ in_cenv_seval(r) }
# gref_m_checked: the GUARDED result-computation for the CLI prove path. It forces `seval` as a
# fail-closed guard (seval `error`s + exits on over-deep recursion BEFORE any proof is built —
# the let is forced in both interp and native), then returns gref_m's OWN R (the circuit's
# value), so the PROVEN R is byte-identical to the circuit (zero guard/circuit value drift).
# seval's accept-set is a SUBSET of the circuit-faithful set (fuel lockstep + short-circuit), so
# whenever seval does not error, gref_m's R is the exact result. (Bypassing this guard by calling
# gprove_sound directly still proves a truncated circuit — out of the soundness threat model.)
fn gref_m_checked(src: String, inputs: List<Pair<String, Int>>) : List<List<Int>> =
  match parse_prog(src) { Program(types, fns, main) =>
    let _guard : List<List<Int>> = seval(main, in_cenv_seval(inputs), fns, types, unroll_fuel(0)) in gref_m(src, inputs) }
# claim-bind the scalar result (first output component) to claimedR
fn build_claim_m(src: String, inputs: List<Pair<String, Int>>, claimedR: List<Int>) : Build =
  match build_multi_m(src, inputs) { (outws, b) =>
    match mkc(claimedR, b) { (wR, b1) => match mks(vhi(outws), wR, b1) { (wd, b2) => mke(wd, b2) } } }
fn gprove_m(src: String, inputs: List<Pair<String, Int>>, claimedR: List<Int>, seed: Int) : Bool =
  match build_claim_m(src, inputs, claimedR) { Build(n, gs, w) => prove_stark(gs, w, seed) }
# --- SOUND path: prove via prove_b3, then verify with the INDEPENDENT witness-free
# verify_b3 (per-row gate soundness + PLONK grand-product wire consistency). Unlike
# gprove_m/prove_stark (a self-check over the witness, no malicious-prover bound), this
# round-trips through the real verifier — accept ==> the committed trace is a consistent
# satisfying assignment with output == claimedR. NOT zero-knowledge here (the witness is
# opened in the clear); use gprove_zk for hiding. Research-grade + UNAUDITED (see soundness.md).
fn gprove_sound(src: String, inputs: List<Pair<String, Int>>, claimedR: List<Int>) : Bool =
  match build_claim_m(src, inputs, claimedR) { Build(n, gs, w) => verify_b3(gs, prove_b3(gs, w)) }
# --- SOUND + ZERO-KNOWLEDGE: randomized-trace ZK (build_claim_zk pads to targetN with
# random dummy rows that hide the openings) then the same sound verify_b3. Heavy (targetN
# is large so the random rows exceed the ~170 query openings) — opt-in via `--zk`.
fn gprove_zk(src: String, inputs: List<Pair<String, Int>>, claimedR: List<Int>, seed: Int, targetN: Int) : Bool =
  match build_claim_zk(src, inputs, claimedR, seed, targetN) { Build(n, gs, w) => verify_b3(gs, prove_b3(gs, w)) }
# --- PUBLIC INPUTS: pin a chosen input wire to a PUBLIC value, via the same is-zero
# gadget (mkc+mks+mke = assert wire - value == 0). The value lands in a GConst gate, so
# it is part of the public statement (absorbed into stmt_seed) and the verifier checks it.
# This upgrades "R is SOME valid output" to "R = f(THESE public inputs)": a wrong public
# input value makes the bind constraint unsatisfiable -> REJECT.
fn bind_input(wire: Int, value: List<Int>, b: Build) : Build =
  match mkc(value, b) { (wv, b1) => match mks(wire, wv, b1) { (wd, b2) => mke(wd, b2) } }
fn bind_inputs(pubs: List<Pair<Int, List<Int>>>, b: Build) : Build =
  match pubs { [] => b; [Pair(wire, value), ...rest] => bind_inputs(rest, bind_input(wire, value, b)) }
fn build_claim_pub(src: String, inputs: List<Pair<String, Int>>, pubs: List<Pair<Int, List<Int>>>, claimedR: List<Int>) : Build =
  match build_multi_m(src, inputs) { (outws, b) =>
    match mkc(claimedR, b) { (wR, b1) => match mks(vhi(outws), wR, b1) { (wd, b2) => bind_inputs(pubs, mke(wd, b2)) } } }
# --- ZK via RANDOMIZED TRACE (full integration, the cleaner route): append k dummy
# GAdd(o,a,b) gates on FRESH wires with random satisfying witness (o = a + b). Each is
# sound-NEUTRAL (the gate holds, so the quotient is unaffected; a,b,o are fresh -> sigma
# fixed-points that cancel in the grand product), and fills l,r,o with RANDOM values. With
# k > the ~170-eval leak surface, the query/OOD openings reveal only the random rows, not
# the witness -> HIDING. No degree blowup, no param change; the verifier is UNCHANGED (just
# a larger n). targetN sizes the trace (256 -> ~240 random rows >> 170 openings).
fn zk_dummy_gates(base: Int, k: Int) : List<Gate> = if k <= 0 then [] else [GAdd(base + 2, base, base + 1)] ++ zk_dummy_gates(base + 3, k - 1)
fn zk_dummy_wit(seed: Int, k: Int, i: Int) : List<List<Int>> =
  if k <= 0 then [] else let a : List<Int> = lane0(hashg(glit(seed), glit(2 * i))) in let b : List<Int> = lane0(hashg(glit(seed), glit(2 * i + 1))) in [a, b, fadd(a, b)] ++ zk_dummy_wit(seed, k - 1, i + 1)
fn build_claim_zk(src: String, inputs: List<Pair<String, Int>>, claimedR: List<Int>, seed: Int, targetN: Int) : Build =
  match build_claim_m(src, inputs, claimedR) { Build(n, gs, w) =>
    let k : Int = targetN - glen(gs) in
    Build(n + 3 * k, gs ++ zk_dummy_gates(n, k), w ++ zk_dummy_wit(seed, k, 1)) }

# --- demo --------------------------------------------------------------------
fn show_a(b: Bool) : String = if b then "ACCEPT" else "REJECT"
fn show_b(b: Bool) : String = if b then "yes" else "no"
# SOUNDNESS GATE assertions: turn the printed ACCEPT/REJECT expectations into hard checks.
# A mismatch (an attack that should REJECT but ACCEPTs, or an honest proof that REJECTs)
# aborts the whole run via the loud `error` builtin -> nonzero exit, so soundness can never
# silently regress under a refactor (the grind-no-op / hash-cap lesson, institutionalized).
# Pure (no IO): return the label on success, abort via `error` on a mismatch. Printing is
# done at the top-level call sites (where IO is allowed), keeping these effect-free.
fn expect_accept(label: String, got: Bool) : String = if got then label else error("SOUNDNESS GATE FAILED: " ++ label ++ " expected ACCEPT but got REJECT")
fn expect_reject(label: String, got: Bool) : String = if got then error("SOUNDNESS GATE FAILED: " ++ label ++ " expected REJECT but got ACCEPT") else label
fn show(xs: List<Int>) : String = match trim(xs) { [] => "0"; [h, ...t] => match t { [] => int_to_string(h); _ => int_to_string(h) ++ " (low limb of " ++ int_to_string(len(trim(xs))) ++ ")" } }
let msrc : String = "fn f(a: Int, b: Int, c: Int) : Int = a * b + c\nf(a, b, c)"
let mins : List<Pair<String, Int>> = [Pair("a", 100000), Pair("b", 100000), Pair("c", 99)]
let mres : List<Int> = gref(msrc, mins)                       # the true result, over Goldilocks
let zk_hide : Bool = zk_hiding(777, 888)                       # ZK blinding hides the witness at openings (fast, no FRI)
let _ : String = print("ZK BLINDING (mechanism): a blinded opening differs from the raw witness AND between masks (hiding): " ++ show_b(zk_hide))
let _ : String = print("  (the full ZK proof — blinded l,r,o,Z through the staged FRI — is the heavy remaining piece; design in docs/tier1-zk-design.md)")
let okm : Bool = gprove(msrc, mins, mres, 11111)              # honest claim -> ACCEPT
let badm : Bool = gprove(msrc, mins, glit(12345), 11111)     # wrong claim -> REJECT
let _ : String = print("--- prove_source_goldilocks_zk.glass: real Glass SOURCE -> a ZK proof over Goldilocks, POSEIDON-hashed ---")
let _ : String = print("source (prism-parsed) -> cgen (multi-input, ==, if) -> committed, F_{p^2}-challenged, query-verified, blinded STARK,")
let _ : String = print("now hashed with the VETTED POSEIDON over Goldilocks (Plonky2-exact, vector-verified) — the educational MiMC is retired.")
let _ : String = print("")
let _ : String = print("  fn f(a, b, c) = a * b + c;  f(a, b, c)   -- a, b, c PRIVATE, over Goldilocks (p = 2^64-2^32+1)")
let _ : String = print("  a=100000, b=100000, c=99  ->  result = " ++ bn_dec(mres) ++ "  (= 10^10 + 99; Baby Bear's 2^31 can't hold this)")
let _ : String = print("  honest claim         -> Poseidon-Merkle-committed, Fiat-Shamir queries verify: " ++ show_a(okm))
let _ : String = print("  wrong claim (R=12345) -> rejected (the output==claim assert breaks): " ++ show_a(badm))
let _ : String = print("")
let _ : String = print("This demo runs the FULL-STRENGTH proof (rho=1/8, coset 16N, 64 queries, real 12-bit grind, ~65-bit provable) + ZK (two seeds),")
let _ : String = print("Poseidon-hashed (~300x MiMC) under the v5.44 GC runtime (~10 MB, no OOM). Run it NATIVELY (run_native.sh / `glass prove`), ~2-3 min;")
let _ : String = print("the reference interpreter is multi-hour for a Poseidon STARK, so the native path is canonical (dogfoods byte-identical there).")
let _ : String = print("Fiat-Shamir now SEEDS the transcript with a digest of the statement (circuit + claimed R), so every challenge depends on it — prover-side")
let _ : String = print("only for now; an independent verifier that re-derives the challenges is the next step. (digest-sensitivity: prove_source_goldilocks_bind_test.glass)")

# --- TIER-1 (WIP) independent-verify scaffolding: round-trip + tamper + the gap ---
let t1b : Build = build_claim_m(msrc, mins, mres)
let t1gs : List<Gate> = build_gates(t1b)
let t1w : List<List<Int>> = build_wit(t1b)
let t1pp : Proof = prove_to_proof(t1gs, t1w, 11111)
let t1honest : Bool = verify(t1gs, t1pp)                                      # round-trip: expect ACCEPT
let t1bgs : List<Gate> = build_gates(build_claim_m(msrc, mins, glit(12345)))  # a DIFFERENT statement (wrong R)
let t1cross : Bool = verify(t1bgs, t1pp)                                      # proof for t1gs, verified vs t1bgs: expect REJECT
let t1nonce : Bool = verify(t1gs, tamper_nonce(t1pp))                         # tampered nonce: expect REJECT
let t1evil : Bool = verify(t1gs, prove_evil(t1gs))                            # P=0, no witness: ACCEPT = the known gap
let _ : String = print("")
let _ : String = print("TIER-1 (WIP) independent verify() — re-derives all challenges from public gates + proof roots:")
let _ : String = print("  honest round-trip          -> " ++ show_a(t1honest) ++ "   (expect ACCEPT)")
let _ : String = print("  cross-statement (wrong R)  -> " ++ show_a(t1cross) ++ "   (expect REJECT)")
let _ : String = print("  tampered nonce             -> " ++ show_a(t1nonce) ++ "   (expect REJECT)")
let _ : String = print("  P=0 evil proof             -> " ++ show_a(t1evil) ++ "   (ACCEPT = the scaffolding gap, pre-part-2)")
let _ : String = print("")
# --- TIER-1 PART 2 (WIP) SOUND verify: OOD-z identity + DEEP-batched FRI on the trace ---
let s_honest : Bool = verify_sound(t1gs, prove_sound(t1gs, t1w))             # expect ACCEPT
let s_cross : Bool = verify_sound(t1bgs, prove_sound(t1gs, t1w))             # proof for t1gs vs t1bgs: expect REJECT
let s_evil : Bool = verify_sound(t1gs, prove_sound_evil(t1gs))              # P=0 attack on the SOUND path: expect REJECT (the headline)
let s_tamper : Bool = verify_sound(t1gs, tamper_strace(prove_sound(t1gs, t1w)))   # tampered trace opening: expect REJECT
let _ : String = print("TIER-1 PART 2 (WIP) SOUND verify() — ties the committed quotient to the gate constraints (per-row):")
let _ : String = print("  honest proof               -> " ++ show_a(s_honest) ++ "   (expect ACCEPT)")
let _ : String = print("  cross-statement (wrong R)  -> " ++ show_a(s_cross) ++ "   (expect REJECT)")
let _ : String = print("  P=0 attack                 -> " ++ show_a(s_evil) ++ "   (expect REJECT <- the OOD identity now CATCHES it; per-row gate-binding)")
let _ : String = print("  tampered trace opening     -> " ++ show_a(s_tamper) ++ "   (expect REJECT; pins the trace<->FRI index alignment)")
let _ : String = print("  CEILING: per-row gate satisfaction ONLY. Inter-row WIRE consistency (a prover threading inconsistent values for the")
let _ : String = print("           same wire across rows, disconnecting R from the real computation) is NOT enforced -> needs B3 (copy/permutation).")
let _ : String = print("           Witness opened in clear (ZK suspended on this path). NOT out of research grade; unaudited; do not protect real value.")
let _ : String = print("")
# --- TIER-1 PART 3 (WIP) B3: copy/permutation argument (the wiring gap) ---
let b3_honest : Bool = verify_b3(t1gs, prove_b3(t1gs, t1w))                  # expect ACCEPT
let b3_cross : Bool = verify_b3(t1bgs, prove_b3(t1gs, t1w))                  # proof for t1gs vs t1bgs: expect REJECT
let _ : String = print("TIER-1 PART 3 (WIP) B3 verify() — adds the grand-product wire-consistency (copy) constraint:")
let _ : String = print("  honest proof               -> " ++ show_a(b3_honest) ++ "   (expect ACCEPT)")
let _ : String = print("  cross-statement (wrong R)  -> " ++ show_a(b3_cross) ++ "   (expect REJECT)")
# THE HEADLINE: a wiring-inconsistent trace. circuit wire2 = w0*w1, then wire3 = wire2*wire2.
# EVIL trace: row0 emits wire2=6 (=2*3), but row1 READS wire2=5 (inconsistent) -> per-row gates
# all hold (6=2*3, 25=5*5) so a per-row check ACCEPTs, but the wire is threaded inconsistently.
let ev_gates : List<Gate> = [GMul(2, 0, 1), GMul(3, 2, 2), GHint(4)]   # 3 gates -> ng=4 -> dsize=128 > 82 queries (no cap; wiring is caught by the PERMUTATION, not the query count)
let ev_l : List<List<Int>> = [glit(2), glit(5), glit(0), glit(0)]      # n=4 (padded); row0 wire2-output side, row1 wire2-INPUT side = 5 (inconsistent)
let ev_r : List<List<Int>> = [glit(3), glit(5), glit(0), glit(0)]
let ev_o : List<List<Int>> = [glit(6), glit(25), glit(7), glit(0)]     # row0 wire2=6, row1 wire3=25, row2 GHint wire4=7 (unconstrained), row3 padding
let ev_perrow : Bool = low_degree_quotient_cols(ev_gates, ev_l, ev_r, ev_o)            # per-row gates DO hold (would pass a per-row check)
let b3_wiring : Bool = verify_b3(ev_gates, prove_b3_cols(ev_gates, ev_l, ev_r, ev_o))  # B3: expect REJECT (wire2 inconsistent across rows)
let _ : String = print("  --- wiring attack (wire2 = 6 as output, 5 as input; per-row gates all hold) ---")
let _ : String = print("  per-row gate check         -> " ++ show_b(ev_perrow) ++ "   (yes: a per-row-only verifier would ACCEPT this)")
let _ : String = print("  B3 grand-product           -> " ++ show_a(b3_wiring) ++ "   (expect REJECT <- the copy constraint CATCHES the inconsistent wire)")
let _ : String = print("  => A+B1+B2+B3: the last NAMED structural soundness hole is closed (a consistent satisfying assignment => genuine R).")
let _ : String = print("     CONCRETE SOUNDNESS: ~80-bit PROVABLE (FRI-query term, 82q x log2(16/9)=68 + 12 grind; conjecture-free unique-decoding) /")
let _ : String = print("     ~135 list-decode (CONJECTURAL). The prior ~32-bit hash-width CAP IS FIXED: hashg now outputs 4 Poseidon lanes (~256-bit ->")
let _ : String = print("     ~128-bit collision binding), so the Merkle + FS commitment binding (~128-bit) no longer gates the ~80-bit FRI term. (The")
let _ : String = print("     32-bit cap was caught by the audit-readiness adversarial pass and fixed here — the integrity discipline working end to end.)")
let _ : String = print("     Queries are now sampled WITHOUT replacement (82 DISTINCT positions), so the full 82-query margin holds (no duplicate erosion).")
let _ : String = print("     All bounds REASONED pen-and-paper, NOT")
let _ : String = print("     machine-verified or audited. ZK SUSPENDED (witness in clear). NOT out of research grade; the EXTERNAL AUDIT is the hard")
let _ : String = print("     boundary (Poseidon unaudited -> if its RO model is false the whole bound is vacuous). Research-grade, audit-pending. Do not protect real value.")
let _ : String = print("")
# --- PUBLIC-INPUT PINNING (closes the 'R is SOME valid output' gap for public inputs) ---
# Pin input wire 0 ('a') to a PUBLIC value, proven on the sound B3 path.
let pin_ok_b : Build = build_claim_pub(msrc, mins, [Pair(0, glit(100000))], mres)
let pin_ok : Bool = match pin_ok_b { Build(pn, pgs, pw) => verify_b3(pgs, prove_b3(pgs, pw)) }      # a pinned to its TRUE value 100000
let pin_bad_b : Build = build_claim_pub(msrc, mins, [Pair(0, glit(99999))], mres)
let pin_bad : Bool = match pin_bad_b { Build(pn, pgs, pw) => verify_b3(pgs, prove_b3(pgs, pw)) }     # a pinned to a WRONG public value 99999
let _ : String = print("TIER-1 PUBLIC-INPUT PINNING (bind input wire 0 = 'a' to a public value in the statement, sound B3 path):")
let _ : String = print("  a pinned to its true value 100000 -> " ++ show_a(pin_ok) ++ "   (expect ACCEPT)")
let _ : String = print("  a pinned to a WRONG value 99999    -> " ++ show_a(pin_bad) ++ "   (expect REJECT <- the proof is now bound to f(THESE public inputs), not just 'some inputs')")
let _ : String = print("")
# --- ZK FULL INTEGRATION: a RANDOMIZED-TRACE proof (n=256, ~240 random dummy rows >> the
# ~170-eval leak surface) proves + verifies on the sound B3 path. The random rows hide the
# witness at the openings (statistical HVZK) while being sound-neutral. ~30-60 min native.
let zk_full_b : Build = build_claim_zk(msrc, mins, mres, 31337, 256)
let zk_full : Bool = match zk_full_b { Build(zn, zgs, zw) => verify_b3(zgs, prove_b3(zgs, zw)) }
let _ : String = print("ZK FULL INTEGRATION (randomized n=256 trace, ~240 random rows hide the ~170 openings) -> " ++ show_a(zk_full) ++ "   (expect ACCEPT: sound + hiding)")
let _ : String = print("")
# === SOUNDNESS GATE === assert every honest case ACCEPTs and every attack REJECTs.
# Any mismatch calls `error` -> the run aborts with a nonzero exit. This makes the demo a
# real regression GATE (not just human-readable prints): a refactor that silently weakens
# verify_b3 can no longer pass. (t1evil/ev_perrow are the DOCUMENTED scaffolding gap +
# per-row-would-accept marker, not soundness guarantees, so they are not gated.)
let _ : String = print("=== SOUNDNESS GATE (each case asserted; a mismatch aborts via `error`) ===")
let _ : String = print("  [OK] " ++ expect_accept("honest (scaffolding verify)", t1honest))
let _ : String = print("  [OK] " ++ expect_reject("cross-statement (scaffolding verify)", t1cross))
let _ : String = print("  [OK] " ++ expect_reject("tampered nonce", t1nonce))
