let _ : String = print("  [OK] " ++ expect_reject("cross-statement (B3 verify)", b3_cross))
let _ : String = print("  [OK] " ++ expect_reject("wiring attack (B3 grand-product)", b3_wiring))
let _ : String = print("  [OK] " ++ expect_accept("public input pinned to true value", pin_ok))
let _ : String = print("  [OK] " ++ expect_reject("public input pinned to WRONG value", pin_bad))
