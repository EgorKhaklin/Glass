 49356, 5743], [16122, 35560, 46490, 14178], [18256, 35089, 35404, 59538], [24293, 42132, 2897, 10820], [65411, 32153, 64811, 32974], [54826, 58911, 31174, 48024], [20532, 33830, 36634, 28284], [56776, 7102, 45790, 5707], [25915, 19804, 12261, 62401], [29154, 60823, 59682, 16569], [6208, 48763, 23311, 21791], [6161, 50379, 10919, 9475], [17222, 19222, 13319, 43757], [51229, 63945, 38587, 36861], [2140, 22839, 37355, 28924], [21568, 24465, 24106, 32633], [54219, 21622, 55775, 17731], [51469, 79, 55102, 61810], [4664, 48328, 50430, 57297], [22780, 32741, 64354, 48269]]
fn p_circ(d: Int) : List<Int> = [17, 15, 41, 16, 2, 28, 13, 13, 39, 18, 34, 20]
fn pzero(n: Int) : List<List<Int>> = if n <= 0 then [] else [glit(0)] ++ pzero(n - 1)
fn hashg(a: List<Int>, b: List<Int>) : List<Int> = wnth(perm(p_arc(0), p_circ(0), [a, b] ++ pzero(10)), 0)

# --- the EXACT digest functions from prove_source_goldilocks_zk.glass ---------
fn gate_dig(g: Gate, acc: List<Int>) : List<Int> = match g {
  GConst(o, c)  => hashg(hashg(hashg(acc, glit(1)), glit(o)), c);
  GAdd(o, a, b) => hashg(hashg(hashg(hashg(acc, glit(2)), glit(o)), glit(a)), glit(b));
  GSub(o, a, b) => hashg(hashg(hashg(hashg(acc, glit(3)), glit(o)), glit(a)), glit(b));
  GMul(o, a, b) => hashg(hashg(hashg(hashg(acc, glit(4)), glit(o)), glit(a)), glit(b));
  GHint(o)      => hashg(hashg(acc, glit(5)), glit(o));
  GEqZero(a)    => hashg(hashg(acc, glit(6)), glit(a)) }
fn circuit_digest(gates: List<Gate>, acc: List<Int>) : List<Int> = match gates { [] => acc; [g, ...rest] => circuit_digest(rest, gate_dig(g, acc)) }
fn stmt_seed_of(gates: List<Gate>) : List<Int> = circuit_digest(gates, glit(2718281))

fn show_b(b: Bool) : String = if b then "yes" else "no"

# a tiny circuit shaped like the demo: out = a*b + c, then claim-bind to R.
# wires: 0=a 1=b 2=c, 3=a*b, 4=ab+c (the output), 5=R const, 6=out-R, assert ==0.
fn circ_R(rval: Int) : List<Gate> =
  [GMul(3, 0, 1), GAdd(4, 3, 2), GConst(5, glit(rval)), GSub(6, 4, 5), GEqZero(6)]
# same circuit, claim-bound to a DIFFERENT R
let cA : List<Gate> = circ_R(10000000099)         # honest result (10^10 + 99)
let cB : List<Gate> = circ_R(12345)               # wrong claim
# a relabeled circuit (swap the two multiplicands' wire indices: structurally different gate)
let cC : List<Gate> = [GMul(3, 1, 0), GAdd(4, 3, 2), GConst(5, glit(10000000099)), GSub(6, 4, 5), GEqZero(6)]

let sA : List<Int> = stmt_seed_of(cA)
let sA2 : List<Int> = stmt_seed_of(cA)
let sB : List<Int> = stmt_seed_of(cB)
let sC : List<Int> = stmt_seed_of(cC)

# Positive semantics: the digest MUST be deterministic (same -> same) AND
# sensitive (any statement change -> a different seed). diffR/diffG are TRUE
# when the seed actually changed, i.e. the binding is doing its job.
let same  : Bool = bn_eq(sA, sA2)
let diffR : Bool = if bn_eq(sA, sB) then false else true
let diffG : Bool = if bn_eq(sA, sC) then false else true
let ok    : Bool = same && diffR && diffG
let _ : String = print("--- statement-binding tamper test (digest must depend on the statement) ---")
let _ : String = print("same circuit       -> same seed     (must be yes): " ++ show_b(same))
let _ : String = print("different R         -> seed changes  (must be yes): " ++ show_b(diffR))
let _ : String = print("reordered operands -> seed changes  (must be yes): " ++ show_b(diffG))
# machine-checkable verdict line the test suite greps for (guards against a no-op regression)
let _ : String = print("BIND-GUARD " ++ (if ok then "PASS" else "FAIL") ++ " same=" ++ show_b(same) ++ " diffR=" ++ show_b(diffR) ++ " diffG=" ++ show_b(diffG))
if ok then "bind test PASS — the FS digest binds circuit structure + claimed R" else "bind test FAIL — the statement-binding digest is a NO-OP"
